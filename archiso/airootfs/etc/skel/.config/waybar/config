{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 0,
    "modules-left": ["custom/menu", "wlr/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "network", "pulseaudio", "backlight", "battery", "custom/nightlight", "custom/power"],

    "custom/menu": {
        "format": "  BlazzCore",
        "on-click": "wofi --show drun --allow-images",
        "tooltip": false
    },

    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "icon-size": 16,
        "icon-theme": "Papirus-Dark",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "close",
        "ignore-list": ["waybar"]
    },

    "clock": {
        "format": "{:%a %b %d  ¬Ζ  %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " {ipaddr}",
        "format-disconnected": "σΑ•Σ No Network",
        "tooltip-format-wifi": "{essid} βÄî {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "on-click": "foot -e nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü Muted",
        "format-icons": {
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && blazzcore-volume-osd",
        "on-scroll-up": "blazzcore-volume up",
        "on-scroll-down": "blazzcore-volume down",
        "tooltip-format": "{desc}: {volume}%"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "blazzcore-brightness up",
        "on-scroll-down": "blazzcore-brightness down"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip-format": "{timeTo} βÄî {capacity}%"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    },

    "custom/nightlight": {
        "exec": "pgrep -x wlsunset >/dev/null && echo 'σΑ¦®' || echo 'σΑ¦®'",
        "interval": 3,
        "on-click": "blazzcore-nightlight",
        "tooltip-format": "Toggle Night Light (Super+N)"
    },

    "custom/power": {
        "format": "βèΜ",
        "on-click": "blazzcore-power",
        "tooltip": false
    }
}
