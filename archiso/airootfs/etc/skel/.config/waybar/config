{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 0,
    "modules-left": ["custom/menu", "wlr/taskbar"],
    "modules-center": ["mpris", "clock"],
    "modules-right": ["tray", "custom/notifications", "custom/updates", "cpu", "memory", "keyboard-state", "network", "pulseaudio", "backlight", "battery", "custom/nightlight", "custom/power"],

    "custom/menu": {
        "format": "вЉћ",
        "on-click": "blazzcore-startmenu",
        "tooltip-format": "Start Menu  (Super+Space)",
        "tooltip": true
    },

    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "icon-size": 16,
        "icon-theme": "Papirus-Dark",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "close",
        "ignore-list": ["waybar"]
    },

    "clock": {
        "format": "{:%a %b %d  В·  %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{player_icon} {dynamic}",
        "player-icons": {
            "default": "в–¶",
            "mpv": "рџЋҐ"
        },
        "status-icons": {
            "paused": "вЏё"
        },
        "dynamic-len": 30,
        "dynamic-importance-order": ["title", "artist", "album"],
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{title}\n{artist}\n{album}"
    },

    "network": {
        "format-wifi": "у°¤Ё {essid}",
        "format-ethernet": "у°€Ђ {ipaddr}",
        "format-disconnected": "у°¤­ No Network",
        "tooltip-format-wifi": "{essid} вЂ” {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "on-click": "foot -e nmtui"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 5,
        "tooltip-format": "CPU: {usage}%  Load: {load}",
        "on-click": "foot -e btop"
    },

    "memory": {
        "format": " {percentage}%",
        "interval": 10,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G",
        "on-click": "foot -e btop"
    },

    "keyboard-state": {
        "numlock": false,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "у°Њ†",
            "unlocked": ""
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "у°ќџ Muted",
        "format-icons": {
            "default": ["у°•ї", "у°•ѕ", "у°•ѕ"],
            "headphone": "у°‹‹",
            "headset": "у°‹Ћ"
        },
        "on-click": "blazzcore-volume mute",
        "on-scroll-up": "blazzcore-volume up",
        "on-scroll-down": "blazzcore-volume down",
        "tooltip-format": "{desc}: {volume}%"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "],
        "on-scroll-up": "blazzcore-brightness up",
        "on-scroll-down": "blazzcore-brightness down"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "у°‚„ {capacity}%",
        "format-plugged": "у°љҐ {capacity}%",
        "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "tooltip-format": "{timeTo} вЂ” {capacity}%"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    },

    "custom/updates": {
        "exec": "COUNT=$(checkupdates 2>/dev/null | wc -l); [ \"$COUNT\" -gt 0 ] && echo \"в†‘ $COUNT\" || echo ''",
        "interval": 3600,
        "on-click": "foot --title='System Update' -e bash -c 'sudo pacman -Syu; echo; echo \"Press Enter to close...\"; read'",
        "tooltip-format": "Updates available вЂ” click to upgrade",
        "return-type": ""
    },

    "custom/notifications": {
        "exec": "swaync-client -swb",
        "exec-if": "which swaync-client",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "notification": "у°‚љ",
            "none": "у°‚њ",
            "dnd-notification": "у°‚›",
            "dnd-none": "у°‚›",
            "inhibited-notification": "у°‚љ",
            "inhibited-none": "у°‚њ"
        },
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "tooltip-format": "Notifications вЂ” right-click to toggle Do Not Disturb",
        "escape": true
    },

    "custom/nightlight": {
        "exec": "pgrep -x wlsunset >/dev/null && echo 'у°›Ё On' || echo ' Off'",
        "interval": 3,
        "on-click": "blazzcore-nightlight",
        "tooltip-format": "Toggle Night Light (Super+N)"
    },

    "custom/power": {
        "format": "вЏ»",
        "on-click": "blazzcore-power",
        "tooltip": false
    }
}
