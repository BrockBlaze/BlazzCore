{
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "spacing": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["custom/menu", "wlr/taskbar"],
    "modules-center": ["mpris"],
    "modules-right": ["tray", "custom/notifications", "custom/updates", "cpu", "memory", "keyboard-state", "network", "pulseaudio", "backlight", "battery", "clock"],

    "custom/menu": {
        "format": "",
        "on-click": "blazzcore-startmenu",
        "tooltip-format": "Start Menu  (Super+Space)",
        "tooltip": true
    },

    "wlr/taskbar": {
        "format": "{icon} {title:.20}",
        "icon-size": 16,
        "icon-theme": "Papirus-Dark",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "minimize",
        "ignore-list": ["waybar"]
    },

    "clock": {
        "format": "{:%a %b %d  ·  %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 60
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{player_icon} {dynamic}",
        "player-icons": {
            "default": "▶",
            "mpv": "🎥"
        },
        "status-icons": {
            "paused": "⏸"
        },
        "dynamic-len": 30,
        "dynamic-importance-order": ["title", "artist", "album"],
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{title}\n{artist}\n{album}"
    },

    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-ethernet": "󰈀 {ipaddr}",
        "format-disconnected": "󰤭 No Network",
        "tooltip-format-wifi": "{essid} — {signalStrength}%\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "on-click": "foot -e nmtui"
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 5,
        "tooltip-format": "CPU: {usage}%  Load: {load}",
        "on-click": "foot -e btop"
    },

    "memory": {
        "format": " {percentage}%",
        "interval": 10,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G",
        "on-click": "foot -e btop"
    },

    "keyboard-state": {
        "numlock": false,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "󰌆",
            "unlocked": ""
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 Muted",
        "format-icons": {
            "default": ["󰕿", "󰕾", "󰕾"],
            "headphone": "󰋋",
            "headset": "󰋎"
        },
        "on-click": "blazzcore-volume mute",
        "on-scroll-up": "blazzcore-volume up",
        "on-scroll-down": "blazzcore-volume down",
        "tooltip-format": "{desc}: {volume}%"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "on-scroll-up": "blazzcore-brightness up",
        "on-scroll-down": "blazzcore-brightness down"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format": "{timeTo} — {capacity}%"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    },

    "custom/updates": {
        "exec": "COUNT=$(checkupdates 2>/dev/null | wc -l); [ \"$COUNT\" -gt 0 ] && echo \"↑ $COUNT\" || echo ''",
        "interval": 3600,
        "on-click": "foot --title='System Update' -e bash -c 'sudo pacman -Syu; echo; echo \"Press Enter to close...\"; read'",
        "tooltip-format": "Updates available — click to upgrade",
        "return-type": ""
    },

    "custom/notifications": {
        "exec": "swaync-client -swb",
        "exec-if": "which swaync-client",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "notification": "󰂚",
            "none": "󰂜",
            "dnd-notification": "󰂛",
            "dnd-none": "󰂛",
            "inhibited-notification": "󰂚",
            "inhibited-none": "󰂜"
        },
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "tooltip-format": "Notifications — right-click to toggle Do Not Disturb",
        "escape": true
    },

    "custom/nightlight": {
        "exec": "pgrep -x wlsunset >/dev/null && echo '󰛨 On' || echo ' Off'",
        "interval": 30,
        "on-click": "blazzcore-nightlight",
        "tooltip-format": "Toggle Night Light (Super+N)"
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "blazzcore-power",
        "tooltip": false
    }
}
