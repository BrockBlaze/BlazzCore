{
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "spacing": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["custom/menu"],
    "modules-center": [],
    "modules-right": ["tray", "pulseaudio", "custom/notifications", "clock"],

    "custom/menu": {
        "format": "󰈸",
        "on-click": "/usr/local/bin/blazzcore-startmenu-toggle",
        "tooltip-format": "Start Menu  (Super+Space)",
        "tooltip": true
    },

    "tray": {
        "icon-size": 16,
        "spacing": 6
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 Muted",
        "format-icons": {
            "default": ["󰕿", "󰕾", "󰕾"],
            "headphone": "󰋋",
            "headset": "󰋎"
        },
        "on-click": "/usr/local/bin/blazzcore-volume mute",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "/usr/local/bin/blazzcore-volume up",
        "on-scroll-down": "/usr/local/bin/blazzcore-volume down",
        "tooltip-format": "{desc}: {volume}%"
    },

    "custom/notifications": {
        "exec": "swaync-client -swb",
        "exec-if": "which swaync-client",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "notification": "󰂚",
            "none": "󰂜",
            "dnd-notification": "󰂛",
            "dnd-none": "󰂛",
            "inhibited-notification": "󰂚",
            "inhibited-none": "󰂜"
        },
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "tooltip-format": "Notifications — right-click to toggle Do Not Disturb",
        "escape": true
    },

    "clock": {
        "format": "{:%a %b %d  ·  %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 60
    }
}
