<?xml version="1.0"?>
<!-- BlazzCore labwc configuration -->
<labwc_config>

  <core>
    <gap>8</gap>
    <adaptiveSync>yes</adaptiveSync>
    <allowTearing>no</allowTearing>
  </core>

  <theme>
    <name>BlazzCore</name>
    <cornerRadius>0</cornerRadius>
    <font place="ActiveWindow">
      <name>Noto Sans</name>
      <size>10</size>
      <weight>Bold</weight>
      <slant>Normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>Noto Sans</name>
      <size>10</size>
      <weight>Normal</weight>
      <slant>Normal</slant>
    </font>
    <titlebar>
      <layout>icon:title,min,max,close</layout>
    </titlebar>
  </theme>

  <desktops>
    <popupTime>500</popupTime>
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
      <name>5</name>
    </names>
  </desktops>

  <resize>
    <popupShow>Never</popupShow>
  </resize>

  <animations>
    <!-- Fade windows in/out on open and close -->
    <animation name="fade" trigger="openclose">
      <enabled>yes</enabled>
      <duration>120</duration>
      <easing>ease-out</easing>
    </animation>
  </animations>

  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>

  <keyboard>
    <default/>

    <!-- Launch apps -->
    <keybind key="Super+Return">
      <action name="Execute"><command>foot</command></action>
    </keybind>
    <keybind key="Super+b">
      <action name="Execute"><command>blazzcore-browser</command></action>
    </keybind>
    <keybind key="Super+d">
      <action name="Execute"><command>blazzcore-startmenu-toggle</command></action>
    </keybind>
    <keybind key="Super+space">
      <action name="Execute"><command>blazzcore-startmenu-toggle</command></action>
    </keybind>
    <keybind key="Super+e">
      <action name="Execute"><command>thunar</command></action>
    </keybind>
    <keybind key="Super+comma">
      <action name="Execute"><command>blazzcore-settings</command></action>
    </keybind>
    <keybind key="Super+v">
      <action name="Execute">
        <command>sh -c "cliphist list | wofi --dmenu --prompt 'Clipboard' | cliphist decode | wl-copy"</command>
      </action>
    </keybind>

    <!-- Window management -->
    <keybind key="Super+shift+q">
      <action name="Close"/>
    </keybind>
    <keybind key="Super+f">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="Super+shift+f">
      <action name="ToggleFullscreen"/>
    </keybind>
    <keybind key="Super+m">
      <action name="Iconify"/>
    </keybind>
    <keybind key="Super+Up">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="Super+Down">
      <action name="Iconify"/>
    </keybind>
    <keybind key="Super+shift+space">
      <action name="ToggleAlwaysOnTop"/>
    </keybind>

    <!-- Snap to halves -->
    <keybind key="Super+Left">
      <action name="SnapToEdge"><direction>left</direction></action>
    </keybind>
    <keybind key="Super+Right">
      <action name="SnapToEdge"><direction>right</direction></action>
    </keybind>

    <!-- Workspaces -->
    <keybind key="Super+1">
      <action name="GoToDesktop"><to>1</to></action>
    </keybind>
    <keybind key="Super+2">
      <action name="GoToDesktop"><to>2</to></action>
    </keybind>
    <keybind key="Super+3">
      <action name="GoToDesktop"><to>3</to></action>
    </keybind>
    <keybind key="Super+4">
      <action name="GoToDesktop"><to>4</to></action>
    </keybind>
    <keybind key="Super+5">
      <action name="GoToDesktop"><to>5</to></action>
    </keybind>
    <keybind key="Super+shift+1">
      <action name="SendToDesktop"><to>1</to></action>
    </keybind>
    <keybind key="Super+shift+2">
      <action name="SendToDesktop"><to>2</to></action>
    </keybind>
    <keybind key="Super+shift+3">
      <action name="SendToDesktop"><to>3</to></action>
    </keybind>
    <keybind key="Super+shift+4">
      <action name="SendToDesktop"><to>4</to></action>
    </keybind>
    <keybind key="Super+shift+5">
      <action name="SendToDesktop"><to>5</to></action>
    </keybind>

    <!-- Alt+Tab window switcher -->
    <keybind key="Alt+Tab">
      <action name="NextWindow"/>
    </keybind>
    <keybind key="Alt+shift+Tab">
      <action name="PreviousWindow"/>
    </keybind>

    <!-- Power -->
    <keybind key="Super+l">
      <action name="Execute"><command>blazzcore-lock</command></action>
    </keybind>
    <keybind key="Super+shift+p">
      <action name="Execute"><command>blazzcore-power</command></action>
    </keybind>
    <keybind key="Control+Shift+Escape">
      <action name="Execute"><command>blazzcore-taskmanager</command></action>
    </keybind>

    <!-- Media keys with OSD -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute"><command>blazzcore-volume up</command></action>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute"><command>blazzcore-volume down</command></action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute"><command>blazzcore-volume mute</command></action>
    </keybind>
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute"><command>blazzcore-brightness up</command></action>
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute"><command>blazzcore-brightness down</command></action>
    </keybind>

    <!-- Screenshots -->
    <keybind key="Print">
      <action name="Execute"><command>blazzcore-screenshot</command></action>
    </keybind>
    <keybind key="Shift+Print">
      <action name="Execute"><command>blazzcore-screenshot area</command></action>
    </keybind>
    <keybind key="Control+Print">
      <action name="Execute"><command>blazzcore-screenshot clip</command></action>
    </keybind>

    <!-- Screen recorder -->
    <keybind key="Super+shift+r">
      <action name="Execute"><command>blazzcore-screenshot record</command></action>
    </keybind>

    <!-- Night light -->
    <keybind key="Super+n">
      <action name="Execute"><command>blazzcore-nightlight</command></action>
    </keybind>

    <!-- Move window to adjacent workspace and follow -->
    <keybind key="Super+shift+Left">
      <action name="SendToDesktop"><to>previous</to><follow>yes</follow></action>
    </keybind>
    <keybind key="Super+shift+Right">
      <action name="SendToDesktop"><to>next</to><follow>yes</follow></action>
    </keybind>

    <!-- Cycle workspaces -->
    <keybind key="Control+Alt+Left">
      <action name="GoToDesktop"><to>previous</to><wrap>yes</wrap></action>
    </keybind>
    <keybind key="Control+Alt+Right">
      <action name="GoToDesktop"><to>next</to><wrap>yes</wrap></action>
    </keybind>
  </keyboard>

  <mouse>
    <!-- Use labwc defaults — this properly handles close/maximize/minimize buttons -->
    <default/>

    <context name="Desktop">
      <!-- Explicitly consume left-click so <default/> binding cannot show a menu -->
      <mousebind button="Left" action="Click">
        <action name="Execute"><command>true</command></action>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="Execute"><command>true</command></action>
      </mousebind>
      <!-- Right-click shows context menu -->
      <mousebind button="Right" action="Click">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
      <mousebind button="Up" action="Scroll">
        <action name="GoToDesktop"><to>previous</to><wrap>yes</wrap></action>
      </mousebind>
      <mousebind button="Down" action="Scroll">
        <action name="GoToDesktop"><to>next</to><wrap>yes</wrap></action>
      </mousebind>
    </context>
  </mouse>

  <windowRules>
    <!-- Force BlazzCore server-side decorations on all windows.
         GTK_CSD=0 (set in autostart) strips GTK3 apps' own CSD so only ours shows.
         GTK4/libadwaita apps that hardcode CSD are listed below with SSD disabled
         to avoid double-decoration. -->
    <windowRule identifier="*">
      <serverDecoration>yes</serverDecoration>
      <action name="AutoPlace"/>
    </windowRule>

    <!-- Apps that hardcode CSD and cannot be overridden — disable SSD to avoid double-decoration -->
    <windowRule identifier="chromium">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="Chromium-browser">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="gnome-calculator">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="org.gnome.Calculator">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="nautilus">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="org.gnome.Nautilus">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="gedit">
      <serverDecoration>no</serverDecoration>
    </windowRule>
    <windowRule identifier="org.gnome.gedit">
      <serverDecoration>no</serverDecoration>
    </windowRule>
  </windowRules>

</labwc_config>
