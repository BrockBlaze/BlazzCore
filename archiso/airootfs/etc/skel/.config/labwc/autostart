#!/bin/bash
# BlazzCore labwc autostart

# Pass Wayland vars to dbus/systemd (includes QT + Firefox native Wayland)
# GTK_CSD=0 disables GTK3 client-side decorations so labwc's titlebar is used instead
export GTK_CSD=0
dbus-update-activation-environment --systemd \
    WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=labwc XDG_SESSION_TYPE=wayland \
    MOZ_ENABLE_WAYLAND=1 QT_QPA_PLATFORM=wayland \
    XCURSOR_THEME=Adwaita XCURSOR_SIZE=24 GTK_CSD=0

# Create standard user folders (Downloads, Pictures, Documents, Desktop, etc.)
xdg-user-dirs-update

# Audio (PipeWire + WirePlumber session manager)
pipewire &
pipewire-pulse &
wireplumber &

# Cursor theme
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24

# Wallpaper (fall back to solid color if image is missing)
# blazzcore-wallpaper updates the WALLPAPER= line below to persist changes
WALLPAPER=/usr/share/backgrounds/blazzcore/deep-space.png
if [[ -f "$WALLPAPER" ]]; then
    swaybg -i "$WALLPAPER" -m fill &
else
    swaybg -c "#0d0d1a" &
fi

# Status bar
waybar &

# Desktop icons
pcmanfm --desktop &

# Polkit authentication agent (allows GUI apps to request elevated privileges)
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Notification center (handles notifications + shows history panel)
swaync &

# System tray: network
nm-applet &

# Bluetooth tray (only if hardware is present)
if ls /sys/class/bluetooth/ 2>/dev/null | grep -q .; then
    blueman-applet &
fi

# Clipboard history daemon
wl-paste --watch cliphist store &

# Volume/brightness OSD pipe
WOB_PIPE=/tmp/wob.pipe
[ -p "$WOB_PIPE" ] || mkfifo "$WOB_PIPE" || { echo "autostart: failed to create wob pipe" >&2; }
wob \
    --background-color "#0e0e1add" \
    --border-color "#4a4a8aff" \
    --bar-color "#8080c8ff" \
    --overflow-background-color "#1a0a0add" \
    --overflow-bar-color "#c0392bff" \
    --overflow-border-color "#c0392bff" \
    --height 28 --offset-y 60 \
    < "$WOB_PIPE" &

# Idle timeouts — edit these values to customize (seconds)
# IDLE_LOCK=300  → lock after 5 min
# IDLE_DPMS=600  → display off after 10 min
IDLE_LOCK=300
IDLE_DPMS=600
swayidle -w \
    timeout "$IDLE_LOCK" 'blazzcore-lock' \
    timeout "$IDLE_DPMS" 'wlopm --off "*"' \
    resume 'wlopm --on "*"' \
    before-sleep 'blazzcore-lock' &

# Ensure ~/Pictures exists for screenshots
mkdir -p ~/Pictures

# GTK dark theme + cursor + icons (first login only — nwg-look can change these after)
_GTK_FLAG="$HOME/.config/blazzcore/gtk_defaults_set"
if [[ ! -f "$_GTK_FLAG" ]]; then
    mkdir -p "$(dirname "$_GTK_FLAG")"
    touch "$_GTK_FLAG"
    gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface cursor-size 24 2>/dev/null || true
    gsettings set org.gnome.desktop.interface enable-animations true 2>/dev/null || true
fi
unset _GTK_FLAG

# Auto-launch installer if booted via "Install BlazzCore" GRUB entry
if grep -qw 'blazzcore_install' /proc/cmdline; then
    (sleep 4 && foot -e sudo -E blazzcore-install) &
fi
