#!/bin/sh
# BlazzCore labwc autostart

# Pass Wayland vars to dbus/systemd
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=labwc XDG_SESSION_TYPE=wayland

# Cursor theme
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24

# Wallpaper (fall back to solid color if image is missing)
# blazzcore-wallpaper updates the WALLPAPER= line below to persist changes
WALLPAPER=/usr/share/backgrounds/blazzcore/default.png
if [[ -f "$WALLPAPER" ]]; then
    swaybg -i "$WALLPAPER" -m fill &
else
    swaybg -c "#0d0d1a" &
fi

# Status bar
waybar &

# Desktop icons
pcmanfm --desktop &

# Polkit authentication agent (allows GUI apps to request elevated privileges)
/usr/lib/xfce-polkit/xfce-polkit &

# Notification center (replaces mako — handles notifications + shows history panel)
swaync &

# System tray: network, bluetooth
nm-applet &
blueman-applet &

# Clipboard history daemon
wl-paste --watch cliphist store &

# Volume/brightness OSD pipe
WOB_PIPE=/tmp/wob.pipe
[ -p "$WOB_PIPE" ] || mkfifo "$WOB_PIPE" || { echo "autostart: failed to create wob pipe" >&2; }
wob \
    --background-color "#0e0e1add" \
    --border-color "#4a4a8aff" \
    --bar-color "#8080c8ff" \
    --overflow-background-color "#1a0a0add" \
    --overflow-bar-color "#c0392bff" \
    --overflow-border-color "#c0392bff" \
    --height 28 --offset-y 60 \
    < "$WOB_PIPE" &

# Dock — full-width taskbar style
nwg-dock -p bottom -a center -i 38 -mb 0 -f &

# Idle timeouts — edit these values to customize (seconds)
# IDLE_LOCK=300  → lock after 5 min
# IDLE_DPMS=600  → display off after 10 min
IDLE_LOCK=300
IDLE_DPMS=600
swayidle -w \
    timeout "$IDLE_LOCK" 'blazzcore-lock' \
    timeout "$IDLE_DPMS" 'wlopm --off "*"' \
    resume 'wlopm --on "*"' \
    before-sleep 'blazzcore-lock' &

# Ensure ~/Pictures exists for screenshots
mkdir -p ~/Pictures

# GTK dark theme + cursor + icons
gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita' 2>/dev/null || true
gsettings set org.gnome.desktop.interface cursor-size 24 2>/dev/null || true
