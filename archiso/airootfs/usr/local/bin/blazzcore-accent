#!/usr/bin/env bash
# BlazzCore — Accent Color Picker
# Updates window border and title bar tint, then reloads labwc theme

SYSTEM_THEMERC="/usr/share/themes/BlazzCore/openbox-3/themerc"
# Write to both: ~/.local/share is the standard labwc theme search path;
# ~/.config/labwc/themerc is the override for labwc 0.7+
USER_THEMERC="$HOME/.local/share/themes/BlazzCore/openbox-3/themerc"
CFG_THEMERC="$HOME/.config/labwc/themerc"

for THEMERC in "$USER_THEMERC" "$CFG_THEMERC"; do
    if [[ ! -f "$THEMERC" ]]; then
        mkdir -p "$(dirname "$THEMERC")"
        cp "$SYSTEM_THEMERC" "$THEMERC"
    fi
done
THEMERC="$USER_THEMERC"

# Open color picker (zenity returns hex like #rrggbb)
CURRENT=$(grep 'window.active.border.color' "$THEMERC" | awk '{print $NF}')
COLOR=$(zenity --color-selection \
    --title="Choose Accent Color" \
    --color="${CURRENT:-#4a9eff}" \
    2>/dev/null)

[[ -z "$COLOR" ]] && exit 0

# Validate format: zenity may return #rrggbb or rgb(r,g,b) — normalise to #rrggbb
if [[ "$COLOR" =~ ^rgb\(([0-9]+),([0-9]+),([0-9]+)\)$ ]]; then
    R="${BASH_REMATCH[1]}"; G="${BASH_REMATCH[2]}"; B="${BASH_REMATCH[3]}"
    COLOR=$(printf '#%02x%02x%02x' "$R" "$G" "$B")
elif [[ "$COLOR" =~ ^#[0-9a-fA-F]{6}$ ]]; then
    R=$(printf '%d' "0x${COLOR:1:2}")
    G=$(printf '%d' "0x${COLOR:3:2}")
    B=$(printf '%d' "0x${COLOR:5:2}")
else
    zenity --error --title="Accent Color" \
        --text="Unrecognised color format: $COLOR" --width=300 2>/dev/null
    exit 1
fi

# Clamp values to 0-255
clamp() { local v=$1; (( v < 0 )) && v=0; (( v > 255 )) && v=255; echo "$v"; }
R=$(clamp "$R"); G=$(clamp "$G"); B=$(clamp "$B")

# Title bar = accent at 20% brightness (very dark tint)
TR=$(printf '%02x' $(( R * 20 / 100 )))
TG=$(printf '%02x' $(( G * 20 / 100 )))
TB=$(printf '%02x' $(( B * 20 / 100 )))
TITLE_COLOR="#${TR}${TG}${TB}"

# Update both themerc copies
for THEMERC in "$USER_THEMERC" "$CFG_THEMERC"; do
    sed -i "s|^window.active.border.color:.*|window.active.border.color:         $COLOR|" "$THEMERC"
    sed -i "s|^window.active.title.bg.color:.*|window.active.title.bg.color:       $TITLE_COLOR|" "$THEMERC"
done

# Point labwc rc.xml at the user theme override
RCXML="$HOME/.config/labwc/rc.xml"
if grep -q '<name>BlazzCore</name>' "$RCXML"; then
    # Already using BlazzCore theme — labwc will pick up ~/.config/labwc/themerc automatically
    :
fi

# Save accent color for other BlazzCore apps (start menu, etc.)
mkdir -p "$HOME/.config/blazzcore"
echo "$COLOR" > "$HOME/.config/blazzcore/accent"

# Reload labwc theme live (no full restart needed)
labwc --reconfigure 2>/dev/null || true

zenity --info \
    --title="Accent Color Applied" \
    --text="Accent color updated to <b>$COLOR</b>.\nWindow borders and title bars updated." \
    --width=320 2>/dev/null
