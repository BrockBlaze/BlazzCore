#!/usr/bin/env bash
# BlazzCore wallpaper picker — opens file chooser, sets wallpaper live

IMG=$(zenity --file-selection \
    --title="Choose Wallpaper" \
    --file-filter="Images | *.png *.jpg *.jpeg *.webp" \
    2>/dev/null)

if [[ -n "$IMG" ]]; then
    # Validate the selected file is a readable image
    if [[ ! -r "$IMG" ]]; then
        zenity --error --title="Wallpaper Error" --text="Cannot read file:\n$IMG" --width=320 2>/dev/null
        exit 1
    fi

    # Kill existing swaybg and start fresh with new wallpaper
    pkill swaybg 2>/dev/null || true
    swaybg -i "$IMG" -m fill &

    # Persist across reboots — update the WALLPAPER variable in autostart
    AUTOSTART="$HOME/.config/labwc/autostart"
    # Escape characters special in sed replacement (& \ |)
    ESCAPED_IMG=$(printf '%s' "$IMG" | sed 's/[&\|]/\\&/g')
    if grep -q '^WALLPAPER=' "$AUTOSTART"; then
        sed -i "s|^WALLPAPER=.*|WALLPAPER=$ESCAPED_IMG|" "$AUTOSTART"
    else
        # Fallback: update the swaybg line directly if WALLPAPER var not present
        sed -i "s|swaybg -i .* -m fill|swaybg -i \"$ESCAPED_IMG\" -m fill|" "$AUTOSTART"
    fi
fi
