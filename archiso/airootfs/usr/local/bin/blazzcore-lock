#!/usr/bin/env bash
# BlazzCore styled lock screen
# Accent colors follow the user's themerc (updated by blazzcore-accent)

# Read accent color from user themerc, fall back to default purple
THEMERC="$HOME/.config/labwc/themerc"
SYSTEM_THEMERC="/usr/share/themes/BlazzCore/openbox-3/themerc"
[[ ! -f "$THEMERC" ]] && THEMERC="$SYSTEM_THEMERC"

# Extract accent hex (strip leading #)
ACCENT=$(grep 'window.active.border.color' "$THEMERC" 2>/dev/null | awk '{print $NF}' | tr -d '#')
ACCENT=${ACCENT:-4a9eff}

# Use current wallpaper from config, fall back to default
_WP_CONF="$HOME/.config/blazzcore/wallpaper.conf"
BG=/usr/share/backgrounds/blazzcore/default.png
if [[ -f "$_WP_CONF" ]]; then
    _MODE=$(grep '^MODE=' "$_WP_CONF" | cut -d= -f2-)
    if [[ "$_MODE" == "image" ]]; then
        _IMG=$(grep '^IMG=' "$_WP_CONF" | cut -d= -f2-)
        [[ -f "$_IMG" ]] && BG="$_IMG"
    fi
fi

SWAYLOCK_ARGS=(
    --scaling fill
    --indicator
    --indicator-radius 80
    --indicator-thickness 6
    --ring-color "$ACCENT"
    --key-hl-color "$ACCENT"
    --line-color 00000000
    --inside-color 1e1e1ecc
    --separator-color 00000000
    --text-color e8e8f0
    --ring-wrong-color c0392b
    --inside-wrong-color 3a0a0acc
    --ring-ver-color 27ae60
    --inside-ver-color 0a1a0acc
    --bs-hl-color c0392b
    --caps-lock-key-hl-color d4ac0d
    --ignore-empty-password
)

if [[ -f "$BG" ]]; then
    exec swaylock --image "$BG" "${SWAYLOCK_ARGS[@]}"
else
    exec swaylock --color 1e1e1e "${SWAYLOCK_ARGS[@]}"
fi
