#!/usr/bin/env bash
# BlazzCore Task Manager — launches btop in a dedicated terminal window
# btop provides a full-featured, beautiful TUI process viewer with
# CPU, memory, disk, network graphs and process management.

if command -v btop &>/dev/null; then
    exec foot --title="Task Manager" -e btop
elif command -v htop &>/dev/null; then
    exec foot --title="Task Manager" -e htop
else
    exec foot --title="Task Manager" -e top
fi
