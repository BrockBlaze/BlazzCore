#!/usr/bin/env python3
# BlazzCore — Tic Tac Toe

import os
import sys

def clear():
    os.system("clear")

def draw(board):
    clear()
    print("\n  ╔═══╦═══╦═══╗")
    for row in range(3):
        cells = []
        for col in range(3):
            val = board[row][col]
            if val == "X":
                cells.append(" \033[1;31mX\033[0m ")
            elif val == "O":
                cells.append(" \033[1;34mO\033[0m ")
            else:
                cells.append(f" \033[90m{board[row][col]}\033[0m ")
        print("  ║" + "║".join(cells) + "║")
        if row < 2:
            print("  ╠═══╬═══╬═══╣")
    print("  ╚═══╩═══╩═══╝")

def check_win(board, player):
    b = board
    for i in range(3):
        if all(b[i][j] == player for j in range(3)): return True
        if all(b[j][i] == player for j in range(3)): return True
    if all(b[i][i] == player for i in range(3)): return True
    if all(b[i][2-i] == player for i in range(3)): return True
    return False

def check_draw(board):
    return all(board[r][c] in ("X", "O") for r in range(3) for c in range(3))

def get_move(board, player, label):
    while True:
        try:
            draw(board)
            print(f"\n  Player {label} ({player}) — enter cell (1-9): ", end="")
            n = int(input())
            if not 1 <= n <= 9:
                continue
            r, c = divmod(n - 1, 3)
            if board[r][c] in ("X", "O"):
                print("  Cell taken, try again.")
                input("  Press Enter...")
                continue
            return r, c
        except (ValueError, EOFError):
            continue

def play():
    players = [("X", "\033[1;31mX\033[0m"), ("O", "\033[1;34mO\033[0m")]
    while True:
        board = [[str(r * 3 + c + 1) for c in range(3)] for r in range(3)]
        turn = 0
        while True:
            symbol, label = players[turn]
            r, c = get_move(board, symbol, label)
            board[r][c] = symbol
            draw(board)
            if check_win(board, symbol):
                print(f"\n  🎉 Player {label} wins!\n")
                break
            if check_draw(board):
                print("\n  It's a draw!\n")
                break
            turn = 1 - turn
        print("  Play again? (y/n): ", end="")
        if input().strip().lower() != "y":
            print()
            break

if __name__ == "__main__":
    try:
        clear()
        print("""
  ╔══════════════════════════╗
  ║   BlazzCore Tic Tac Toe  ║
  ╚══════════════════════════╝
  Numbers 1-9 map to the grid:
    1 │ 2 │ 3
   ───┼───┼───
    4 │ 5 │ 6
   ───┼───┼───
    7 │ 8 │ 9

  Press Enter to start...
        """)
        input()
        play()
    except KeyboardInterrupt:
        print("\n  Bye!\n")
