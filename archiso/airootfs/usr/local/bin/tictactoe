#!/usr/bin/env python3
# BlazzCore — Tic Tac Toe (with singleplayer bot)

import os
import random
import time

def clear():
    os.system("clear")

def draw(board, msg=""):
    clear()
    print("\n  ╔═══╦═══╦═══╗")
    for row in range(3):
        cells = []
        for col in range(3):
            val = board[row][col]
            if val == "X":
                cells.append(" \033[1;31mX\033[0m ")
            elif val == "O":
                cells.append(" \033[1;34mO\033[0m ")
            else:
                cells.append(f" \033[90m{val}\033[0m ")
        print("  ║" + "║".join(cells) + "║")
        if row < 2:
            print("  ╠═══╬═══╬═══╣")
    print("  ╚═══╩═══╩═══╝")
    if msg:
        print(f"\n  {msg}")

def check_win(board, p):
    b = board
    for i in range(3):
        if all(b[i][j] == p for j in range(3)): return True
        if all(b[j][i] == p for j in range(3)): return True
    if all(b[i][i] == p for i in range(3)): return True
    if all(b[i][2-i] == p for i in range(3)): return True
    return False

def check_draw(board):
    return all(board[r][c] in ("X", "O") for r in range(3) for c in range(3))

def empty_cells(board):
    return [(r, c) for r in range(3) for c in range(3) if board[r][c] not in ("X", "O")]

# --- Minimax AI ---
def minimax(board, is_maximizing, bot, human, depth=0):
    if check_win(board, bot):   return 10 - depth
    if check_win(board, human): return depth - 10
    if check_draw(board):       return 0

    if is_maximizing:
        best = -100
        for r, c in empty_cells(board):
            board[r][c] = bot
            best = max(best, minimax(board, False, bot, human, depth + 1))
            board[r][c] = str(r * 3 + c + 1)
        return best
    else:
        best = 100
        for r, c in empty_cells(board):
            board[r][c] = human
            best = min(best, minimax(board, True, bot, human, depth + 1))
            board[r][c] = str(r * 3 + c + 1)
        return best

def bot_move(board, bot, human, difficulty):
    cells = empty_cells(board)
    if difficulty == "easy":
        # 70% random, 30% smart
        if random.random() < 0.7:
            return random.choice(cells)
    elif difficulty == "medium":
        # Play smart only if can win or must block, else random
        for r, c in cells:
            board[r][c] = bot
            if check_win(board, bot):
                board[r][c] = str(r * 3 + c + 1)
                return r, c
            board[r][c] = str(r * 3 + c + 1)
        for r, c in cells:
            board[r][c] = human
            if check_win(board, human):
                board[r][c] = str(r * 3 + c + 1)
                return r, c
            board[r][c] = str(r * 3 + c + 1)
        return random.choice(cells)

    # Hard: full minimax
    best_score, best_move = -100, None
    for r, c in cells:
        board[r][c] = bot
        score = minimax(board, False, bot, human, 0)
        board[r][c] = str(r * 3 + c + 1)
        if score > best_score:
            best_score, best_move = score, (r, c)
    return best_move

def get_player_move(board, symbol):
    while True:
        try:
            draw(board, f"Your turn (\033[1;31m{symbol}\033[0m) — enter cell (1-9): ")
            n = int(input("  > "))
            if not 1 <= n <= 9:
                continue
            r, c = divmod(n - 1, 3)
            if board[r][c] in ("X", "O"):
                draw(board, "Cell taken, try again.")
                time.sleep(0.8)
                continue
            return r, c
        except (ValueError, EOFError):
            continue

def choose(prompt, options):
    """Simple numbered menu, returns chosen value."""
    while True:
        clear()
        print(f"\n  {prompt}\n")
        for i, (label, _) in enumerate(options, 1):
            print(f"    {i}. {label}")
        print()
        try:
            n = int(input("  > "))
            if 1 <= n <= len(options):
                return options[n - 1][1]
        except (ValueError, EOFError):
            continue

def play_singleplayer():
    difficulty = choose("Choose difficulty:", [
        ("Easy",   "easy"),
        ("Medium", "medium"),
        ("Hard",   "hard"),
    ])
    human_sym = choose("Choose your symbol:", [
        ("X  (goes first)", "X"),
        ("O  (goes second)", "O"),
    ])
    bot_sym = "O" if human_sym == "X" else "X"

    while True:
        board = [[str(r * 3 + c + 1) for c in range(3)] for r in range(3)]
        # X always goes first
        turn = "X"
        while True:
            if turn == human_sym:
                r, c = get_player_move(board, human_sym)
                board[r][c] = human_sym
                draw(board)
                if check_win(board, human_sym):
                    draw(board, "🎉 You win!\n")
                    break
            else:
                draw(board, f"Bot is thinking... (\033[1;34m{bot_sym}\033[0m)")
                time.sleep(0.6)
                r, c = bot_move(board, bot_sym, human_sym, difficulty)
                board[r][c] = bot_sym
                draw(board)
                if check_win(board, bot_sym):
                    draw(board, f"🤖 Bot wins! Better luck next time.\n")
                    break

            if check_draw(board):
                draw(board, "It's a draw!\n")
                break
            turn = "O" if turn == "X" else "X"

        print("  Play again? (y/n): ", end="")
        if input().strip().lower() != "y":
            break

def play_multiplayer():
    players = [("X", "\033[1;31mX\033[0m"), ("O", "\033[1;34mO\033[0m")]
    while True:
        board = [[str(r * 3 + c + 1) for c in range(3)] for r in range(3)]
        turn = 0
        while True:
            symbol, label = players[turn]
            r, c = get_player_move(board, symbol)
            board[r][c] = symbol
            draw(board)
            if check_win(board, symbol):
                draw(board, f"🎉 Player {label} wins!\n")
                break
            if check_draw(board):
                draw(board, "It's a draw!\n")
                break
            turn = 1 - turn
        print("  Play again? (y/n): ", end="")
        if input().strip().lower() != "y":
            break

if __name__ == "__main__":
    try:
        clear()
        print("""
  ╔══════════════════════════╗
  ║   BlazzCore Tic Tac Toe  ║
  ╚══════════════════════════╝
  Numbers 1-9 map to the grid:
    1 │ 2 │ 3
   ───┼───┼───
    4 │ 5 │ 6
   ───┼───┼───
    7 │ 8 │ 9

  Press Enter to start...
        """)
        input()
        mode = choose("Game mode:", [
            ("Singleplayer  (vs Bot)", "single"),
            ("Multiplayer   (2 players)", "multi"),
        ])
        if mode == "single":
            play_singleplayer()
        else:
            play_multiplayer()
        print("\n  Thanks for playing BlazzCore Tic Tac Toe!\n")
    except KeyboardInterrupt:
        print("\n  Bye!\n")
