#!/usr/bin/env python3
# ============================================
# BlazzCore Start Menu
# Left: all apps (alphabetical, searchable)
# Right: Quick Access shortcuts (user-configurable)
# Right-click any app → Pin to Quick Access / Pin to Taskbar
# Right-click a pinned shortcut → Remove / Unpin from Taskbar
# ============================================

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, Gio, GtkLayerShell, GLib
import json, os, subprocess, shlex

# ---- Paths -------------------------------------------------
CFG_DIR        = os.path.expanduser("~/.config/blazzcore")
PINNED_QA_FILE = os.path.join(CFG_DIR, "startmenu-pinned.json")
DOCK_PINNED    = os.path.expanduser("~/.config/nwg-dock/pinned")
DOCK_CONF      = os.path.join(CFG_DIR, "dock.conf")

_DOCK_MARGINS  = {'bottom': '-mb', 'left': '-ml', 'right': '-mr', 'top': '-mt'}

def _dock_cmd():
    pos = 'bottom'
    try:
        for line in open(DOCK_CONF):
            if line.startswith('DOCK_POSITION='):
                pos = line.split('=', 1)[1].strip()
                break
    except FileNotFoundError:
        pass
    margin = _DOCK_MARGINS.get(pos, '-mb')
    return f"nwg-dock -p {pos} -a center -i 42 {margin} 0 -f"

# ---- Built-in shortcuts (always in Quick Access) -----------
BUILTIN = [
    ("Files",           "system-file-manager",      "thunar",              True),
    ("Terminal",        "utilities-terminal",        "foot",                True),
    ("Settings",        "preferences-system",        "blazzcore-settings",  True),
    ("Browser",         "web-browser",               "blazzcore-browser",   True),
    ("Downloads",       "folder-download",           "thunar ~/Downloads",  True),
    ("Documents",       "folder-documents",          "thunar ~/Documents",  True),
]

# ---- Stylesheet --------------------------------------------
