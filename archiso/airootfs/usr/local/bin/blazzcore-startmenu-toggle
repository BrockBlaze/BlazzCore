#!/usr/bin/env bash
# BlazzCore — start menu toggle
# Closes the menu if running, opens it if not.
# Logs any Python errors to /tmp/blazzcore-startmenu.log

if pkill -f 'python3.*blazzcore-startmenu$'; then
    exit 0
fi

exec python3 /usr/local/bin/blazzcore-startmenu \
    >>/tmp/blazzcore-startmenu.log 2>&1
