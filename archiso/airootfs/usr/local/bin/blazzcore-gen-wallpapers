#!/usr/bin/env python3
"""
BlazzCore — Generate default wallpapers at build time.
Creates 3 minimal dark wallpapers as PNG files.

Resolution priority:
  1. WxH argument   e.g. blazzcore-gen-wallpapers 2560x1440
  2. $WALLPAPER_RES environment variable
  3. wlr-randr/wdisplays detection
  4. Fallback: 1920x1080

Usage:
  blazzcore-gen-wallpapers [WxH]          — generate default wallpapers
  blazzcore-gen-wallpapers --color #hex   — generate a custom gradient from a color
"""
import struct, zlib, math, os, re, subprocess, sys

def detect_resolution():
    """Try to detect the primary display resolution from the running compositor."""
    # Try wlr-randr (labwc/wlroots)
    try:
        out = subprocess.check_output(['wlr-randr'], stderr=subprocess.DEVNULL, text=True)
        for line in out.splitlines():
            if 'current' in line.lower():
                parts = line.split()
                for p in parts:
                    if re.match(r'^\d+x\d+$', p):
                        w, h = p.split('x')
                        return int(w), int(h)
    except Exception:
        pass
    return 1920, 1080

# --- Custom color mode: --color #rrggbb ---
if '--color' in sys.argv:
    idx = sys.argv.index('--color')
    hex_color = sys.argv[idx + 1] if idx + 1 < len(sys.argv) else '#0a1e50'
    if not re.match(r'^#[0-9a-fA-F]{6}$', hex_color):
        print(f'Invalid color: {hex_color}'); sys.exit(1)
    br, bg, bb = int(hex_color[1:3], 16), int(hex_color[3:5], 16), int(hex_color[5:7], 16)
    W, H = detect_resolution()
    USER_OUT = os.path.expanduser('~/.local/share/backgrounds/blazzcore')
    os.makedirs(USER_OUT, exist_ok=True)
    print(f'Generating custom gradient from {hex_color} at {W}x{H}')
    pixels = []
    for y in range(H):
        for x in range(W):
            t = y / H
            r = int(br * 0.04 + t * br * 0.35)
            g = int(bg * 0.04 + t * bg * 0.35)
            b = int(bb * 0.04 + t * bb * 0.55)
            dx = (x / W - 0.5) * 2
            dy = (y / H - 0.5) * 2
            v = max(0.0, 1.0 - (dx*dx + dy*dy) * 0.3)
            pixels.append((min(255, int(r*v)), min(255, int(g*v)), min(255, int(b*v))))
    write_png(f'{USER_OUT}/custom.png', pixels)
    print(f'Custom wallpaper saved to {USER_OUT}/custom.png')
    sys.exit(0)

# Resolution from CLI arg, env var, or detection
if len(sys.argv) > 1 and 'x' in sys.argv[1]:
    try:
        W, H = map(int, sys.argv[1].lower().split('x'))
    except ValueError:
        W, H = detect_resolution()
elif 'WALLPAPER_RES' in os.environ and 'x' in os.environ['WALLPAPER_RES']:
    try:
        W, H = map(int, os.environ['WALLPAPER_RES'].lower().split('x'))
    except ValueError:
        W, H = detect_resolution()
else:
    W, H = detect_resolution()

print(f'Generating wallpapers at {W}x{H}')

def write_png(path, pixels):
    """Write raw RGB pixel list (W*H tuples) to PNG."""
    def chunk(tag, data):
        c = struct.pack('>I', len(data)) + tag + data
        return c + struct.pack('>I', zlib.crc32(tag + data) & 0xffffffff)
    ihdr = struct.pack('>IIBBBBB', W, H, 8, 2, 0, 0, 0)
    raw  = b''
    for y in range(H):
        row = b'\x00'
        for x in range(W):
            r, g, b = pixels[y * W + x]
            row += bytes([r, g, b])
        raw += row
    idat = zlib.compress(raw, 6)
    with open(path, 'wb') as f:
        f.write(b'\x89PNG\r\n\x1a\n')
        f.write(chunk(b'IHDR', ihdr))
        f.write(chunk(b'IDAT', idat))
        f.write(chunk(b'IEND', b''))

OUT = '/usr/share/backgrounds/blazzcore'
os.makedirs(OUT, exist_ok=True)

# Cache check — skip generation if all wallpapers exist at the right resolution
CACHE_STAMP = f'{OUT}/.res_{W}x{H}'
WALLPAPERS = ['midnight-blue.png', 'mesh.png', 'charcoal.png']
if os.path.exists(CACHE_STAMP) and all(os.path.exists(f'{OUT}/{w}') for w in WALLPAPERS):
    print(f'Wallpapers already generated at {W}x{H}, skipping.')
    sys.exit(0)

# --- 1. Midnight Blue (default) ---
# Dark grey top → subtle blue glow at bottom-center, vignette edges
print('Generating: midnight-blue.png')
pixels = []
for y in range(H):
    for x in range(W):
        nx, ny = x / W, y / H
        # Base: dark grey gradient
        base_r, base_g, base_b = 20, 20, 22
        # Blue glow from bottom-center
        gx = (nx - 0.5) * 2
        gy = (ny - 0.7) * 3
        glow = max(0.0, 1.0 - (gx*gx + gy*gy))
        glow = glow ** 2.5  # sharpen falloff
        r = int(base_r + glow * 20)
        g = int(base_g + glow * 55)
        b = int(base_b + glow * 120)
        # Vignette
        vx = (nx - 0.5) * 2
        vy = (ny - 0.5) * 2
        v = max(0.0, 1.0 - (vx*vx + vy*vy) * 0.4)
        pixels.append((min(255, int(r*v)), min(255, int(g*v)), min(255, int(b*v))))
write_png(f'{OUT}/midnight-blue.png', pixels)

# --- 2. Mesh gradient (blue + teal flowing waves) ---
print('Generating: mesh.png')
pixels = []
for y in range(H):
    for x in range(W):
        nx, ny = x / W, y / H
        # Multiple overlapping sine waves
        w1 = math.sin(nx * 4.0 + ny * 2.5) * 0.5 + 0.5
        w2 = math.sin(nx * 2.0 - ny * 3.5 + 1.5) * 0.5 + 0.5
        w3 = math.sin((nx + ny) * 3.0 + 0.8) * 0.5 + 0.5
        blend = (w1 * 0.4 + w2 * 0.35 + w3 * 0.25)
        # Dark grey base with blue-teal accent
        r = int(22 + blend * 18)
        g = int(22 + blend * 45)
        b = int(25 + blend * 80)
        # Vignette
        vx = (nx - 0.5) * 2
        vy = (ny - 0.5) * 2
        v = max(0.0, 1.0 - (vx*vx + vy*vy) * 0.3)
        pixels.append((min(255, int(r*v)), min(255, int(g*v)), min(255, int(b*v))))
write_png(f'{OUT}/mesh.png', pixels)

# --- 3. Charcoal (dark grey diagonal, neutral) ---
print('Generating: charcoal.png')
pixels = []
for y in range(H):
    for x in range(W):
        t = (x / W + y / H) / 2
        v = int(22 + t * 20)
        pixels.append((v, v, v))
write_png(f'{OUT}/charcoal.png', pixels)

# Symlink default
default = f'{OUT}/default.png'
if os.path.lexists(default):
    os.remove(default)
os.symlink(f'{OUT}/midnight-blue.png', default)

# Write cache stamp so we skip regeneration next run at same resolution
open(CACHE_STAMP, 'w').close()

print(f'Wallpapers generated at {W}x{H}.')
