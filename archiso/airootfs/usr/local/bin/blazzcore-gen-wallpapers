#!/usr/bin/env python3
"""
BlazzCore — Generate default wallpapers at build time.
Creates 3 minimal dark wallpapers as PNG files.

Resolution priority:
  1. WxH argument   e.g. blazzcore-gen-wallpapers 2560x1440
  2. $WALLPAPER_RES environment variable
  3. wlr-randr/wdisplays detection
  4. Fallback: 1920x1080
"""
import struct, zlib, math, os, subprocess, sys

def detect_resolution():
    """Try to detect the primary display resolution from the running compositor."""
    # Try wlr-randr (labwc/wlroots)
    try:
        out = subprocess.check_output(['wlr-randr'], stderr=subprocess.DEVNULL, text=True)
        for line in out.splitlines():
            if 'current' in line.lower():
                parts = line.split()
                for p in parts:
                    if 'x' in p and p.replace('x', '').replace('0123456789', '').strip() == '':
                        w, h = p.split('x')
                        return int(w), int(h)
    except Exception:
        pass
    return 1920, 1080

# Resolution from CLI arg, env var, or detection
if len(sys.argv) > 1 and 'x' in sys.argv[1]:
    try:
        W, H = map(int, sys.argv[1].lower().split('x'))
    except ValueError:
        W, H = detect_resolution()
elif 'WALLPAPER_RES' in os.environ and 'x' in os.environ['WALLPAPER_RES']:
    try:
        W, H = map(int, os.environ['WALLPAPER_RES'].lower().split('x'))
    except ValueError:
        W, H = detect_resolution()
else:
    W, H = detect_resolution()

print(f'Generating wallpapers at {W}x{H}')

def write_png(path, pixels):
    """Write raw RGB pixel list (W*H tuples) to PNG."""
    def chunk(tag, data):
        c = struct.pack('>I', len(data)) + tag + data
        return c + struct.pack('>I', zlib.crc32(tag + data) & 0xffffffff)
    ihdr = struct.pack('>IIBBBBB', W, H, 8, 2, 0, 0, 0)
    raw  = b''
    for y in range(H):
        row = b'\x00'
        for x in range(W):
            r, g, b = pixels[y * W + x]
            row += bytes([r, g, b])
        raw += row
    idat = zlib.compress(raw, 6)
    with open(path, 'wb') as f:
        f.write(b'\x89PNG\r\n\x1a\n')
        f.write(chunk(b'IHDR', ihdr))
        f.write(chunk(b'IDAT', idat))
        f.write(chunk(b'IEND', b''))

OUT = '/usr/share/backgrounds/blazzcore'
os.makedirs(OUT, exist_ok=True)

# Cache check — skip generation if all wallpapers exist at the right resolution
CACHE_STAMP = f'{OUT}/.res_{W}x{H}'
WALLPAPERS = ['deep-space.png', 'aurora.png', 'charcoal.png']
if os.path.exists(CACHE_STAMP) and all(os.path.exists(f'{OUT}/{w}') for w in WALLPAPERS):
    print(f'Wallpapers already generated at {W}x{H}, skipping.')
    sys.exit(0)

# --- 1. Deep space gradient (default) ---
print('Generating: deep-space.png')
pixels = []
for y in range(H):
    for x in range(W):
        t  = y / H
        r  = int(8  + t * 4)
        g  = int(8  + t * 6)
        b  = int(18 + t * 20)
        # subtle vignette
        dx = (x / W - 0.5) * 2
        dy = (y / H - 0.5) * 2
        v  = max(0.0, 1.0 - (dx*dx + dy*dy) * 0.35)
        pixels.append((int(r*v), int(g*v), int(b*v)))
write_png(f'{OUT}/deep-space.png', pixels)

# --- 2. Dark aurora (teal-purple gradient) ---
print('Generating: aurora.png')
pixels = []
for y in range(H):
    for x in range(W):
        nx = x / W
        ny = y / H
        wave = math.sin(nx * 6 + ny * 4) * 0.5 + 0.5
        r = int((0.04 + wave * 0.06) * 255)
        g = int((0.08 + wave * 0.10) * 255)
        b = int((0.14 + wave * 0.18) * 255)
        dx = (nx - 0.5) * 2
        dy = (ny - 0.5) * 2
        v  = max(0.0, 1.0 - (dx*dx + dy*dy) * 0.4)
        pixels.append((int(r*v), int(g*v), int(b*v)))
write_png(f'{OUT}/aurora.png', pixels)

# --- 3. Charcoal (ultra-minimal near-black) ---
print('Generating: charcoal.png')
pixels = []
for y in range(H):
    for x in range(W):
        t = (x / W + y / H) / 2
        v = int(12 + t * 8)
        pixels.append((v, v, v + 2))
write_png(f'{OUT}/charcoal.png', pixels)

# Symlink default
default = f'{OUT}/default.png'
if os.path.lexists(default):
    os.remove(default)
os.symlink(f'{OUT}/deep-space.png', default)

# Write cache stamp so we skip regeneration next run at same resolution
open(CACHE_STAMP, 'w').close()

print(f'Wallpapers generated at {W}x{H}.')
