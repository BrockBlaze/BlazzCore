#!/usr/bin/env bash
# BlazzCore First Boot Setup Wizard

export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# --- Welcome ---
zenity --info \
    --title="Welcome to BlazzCore" \
    --text="<big><b>Welcome to BlazzCore</b></big>\n\nLet's set up your system.\nThis will only take a moment." \
    --width=400 --ok-label="Get Started" 2>/dev/null || exit 0

# --- Timezone ---
TZ=$(timedatectl list-timezones | zenity --list \
    --title="Select Timezone" \
    --text="Choose your timezone:" \
    --column="Timezone" \
    --width=500 --height=500 \
    --print-column=1 2>/dev/null)

if [[ -n "$TZ" ]]; then
    if timedatectl list-timezones | grep -qx "$TZ"; then
        sudo timedatectl set-timezone "$TZ"
    else
        zenity --error --title="Invalid Timezone" --text="Could not set timezone: '$TZ'" --width=300 2>/dev/null
    fi
fi

# --- Locale ---
LOCALE=$(zenity --list \
    --title="Select Language" \
    --text="Choose your language:" \
    --column="Locale" \
    "en_US.UTF-8" "en_GB.UTF-8" "en_AU.UTF-8" "en_CA.UTF-8" \
    "de_DE.UTF-8" "de_AT.UTF-8" "de_CH.UTF-8" \
    "fr_FR.UTF-8" "fr_CA.UTF-8" "fr_BE.UTF-8" \
    "es_ES.UTF-8" "es_MX.UTF-8" "es_AR.UTF-8" \
    "it_IT.UTF-8" "pt_BR.UTF-8" "pt_PT.UTF-8" \
    "nl_NL.UTF-8" "nl_BE.UTF-8" \
    "sv_SE.UTF-8" "da_DK.UTF-8" "nb_NO.UTF-8" "fi_FI.UTF-8" \
    "pl_PL.UTF-8" "cs_CZ.UTF-8" "sk_SK.UTF-8" "hu_HU.UTF-8" \
    "ro_RO.UTF-8" "tr_TR.UTF-8" "ru_RU.UTF-8" "uk_UA.UTF-8" \
    "ja_JP.UTF-8" "zh_CN.UTF-8" "zh_TW.UTF-8" "ko_KR.UTF-8" \
    "ar_SA.UTF-8" "he_IL.UTF-8" "fa_IR.UTF-8" \
    --width=420 --height=500 2>/dev/null)

if [[ -n "$LOCALE" ]]; then
    echo "LANG=$LOCALE" | sudo tee /etc/locale.conf > /dev/null
    echo "$LOCALE UTF-8" | sudo tee /etc/locale.gen > /dev/null
    sudo locale-gen
fi

# --- Keyboard Layout ---
KEYMAP=$(localectl list-keymaps 2>/dev/null | zenity --list \
    --title="Keyboard Layout" \
    --text="Choose your keyboard layout:" \
    --column="Layout" \
    --width=400 --height=500 \
    --print-column=1 2>/dev/null)

if [[ -n "$KEYMAP" ]]; then
    sudo localectl set-keymap "$KEYMAP"
fi

# --- Hostname ---
HOSTNAME=$(zenity --entry \
    --title="Computer Name" \
    --text="Enter a name for this computer\n(letters, numbers, hyphens only):" \
    --entry-text="blazzcore" \
    --width=380 2>/dev/null)

if [[ -n "$HOSTNAME" ]] && [[ "$HOSTNAME" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]{0,62}$ ]]; then
    echo "$HOSTNAME" | sudo tee /etc/hostname > /dev/null
    sudo hostnamectl set-hostname "$HOSTNAME" 2>/dev/null || true
fi

# --- Password ---
if zenity --question \
    --title="Set Password" \
    --text="Would you like to set a login password?" \
    --ok-label="Set Password" --cancel-label="Skip" \
    --width=380 2>/dev/null; then
    while true; do
        PASS1=$(zenity --password --title="New Password" --width=340 2>/dev/null) || break
        PASS2=$(zenity --password --title="Confirm Password" --width=340 2>/dev/null) || break
        if [[ "$PASS1" == "$PASS2" ]]; then
            echo "${USER:-blazzcore}:$PASS1" | sudo chpasswd && \
            zenity --info --title="Password Set" \
                --text="Password updated successfully." --width=300 2>/dev/null
            break
        else
            zenity --error --title="Password Mismatch" \
                --text="Passwords do not match. Please try again." --width=320 2>/dev/null
        fi
    done
fi

# --- Network ---
WIFI=$(zenity --question \
    --title="Network Setup" \
    --text="Would you like to connect to Wi-Fi now?" \
    --ok-label="Yes, connect" --cancel-label="Skip" \
    --width=400 2>/dev/null && echo "yes" || echo "no")

if [[ "$WIFI" == "yes" ]]; then
    foot -e nmtui
fi

# --- Done ---
zenity --info \
    --title="Setup Complete" \
    --text="<big><b>You're all set!</b></big>\n\nBlazzCore is ready to use.\n\n<b>Useful shortcuts:</b>\n• Super+Enter  — Terminal\n• Super+B  — Browser\n• Super+D  — App launcher\n• Right-click  — Desktop menu" \
    --width=450 2>/dev/null
