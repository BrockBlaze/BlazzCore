def page_nightlight():
    s, b = page_box()
    b.pack_start(page_title('Night Light', 'Reduce blue light with warm color temperature'), False, False, 0)

    c1 = card()
    is_on = subprocess.run(['pgrep', '-x', 'wlsunset'], capture_output=True).returncode == 0
    sw = Gtk.Switch()
    sw.set_active(is_on)
    sw.connect('notify::active', lambda *_: run_bg('blazzcore-nightlight'))
    c1.pack_start(row('Enable Night Light', 'Reduce eye strain by warming the screen color', sw), False, False, 0)
    b.pack_start(c1, False, False, 0)

    c2 = card()
    night_t = int(conf_get(NL_CONF, 'NIGHT_TEMP', '3500'))
    day_t   = int(conf_get(NL_CONF, 'DAY_TEMP',   '6500'))

    def temp_row(label, val, lo, hi, key):
        hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        lbl = Gtk.Label(label=label, xalign=0)
        lbl.set_size_request(140, -1)
        sc = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, lo, hi, 100)
        sc.set_value(val); sc.set_draw_value(False); sc.set_size_request(200, -1)
        vl = Gtk.Label(label=f'{val}K'); vl.set_size_request(55, -1)
        def on_change(sc, vl=vl, k=key):
            v = int(sc.get_value()); vl.set_text(f'{v}K'); conf_set(NL_CONF, k, str(v))
        sc.connect('value-changed', on_change)
        hb.pack_start(lbl, False, False, 0)
        hb.pack_start(sc, True, True, 0)
        hb.pack_start(vl, False, False, 0)
        return hb

    c2.pack_start(temp_row('Night (warm)', night_t, 1000, 6500,  'NIGHT_TEMP'), False, False, 0)
    c2.pack_start(hsep(), False, False, 0)
    c2.pack_start(temp_row('Day (cool)',   day_t,   3000, 10000, 'DAY_TEMP'),   False, False, 0)
    b.pack_start(c2, False, False, 0)
    return s

def page_keyboard():
    s, b = page_box()
    b.pack_start(page_title('Keyboard', 'Set your keyboard input layout'), False, False, 0)

    cur_layout = _shell(['localectl', 'get-keymap']) or 'us'

    cur_lbl = Gtk.Label(label=f'Current layout:  {cur_layout}', xalign=0)
    cur_lbl.get_style_context().add_class('dim')
    cur_lbl.set_margin_bottom(12)
    b.pack_start(cur_lbl, False, False, 0)

    try:
        keymaps = _shell(['localectl', 'list-keymaps']).splitlines()
    except Exception:
        keymaps = ['us', 'uk', 'de', 'fr', 'es']

    st = status_label('Double-click a layout to apply it.')

    def apply_layout(layout):
        result = subprocess.run(['sudo', 'localectl', 'set-keymap', layout],
                                capture_output=True, text=True)
        if result.returncode == 0:
            cur_lbl.set_text(f'Current layout:  {layout}')
            st.set_text(f'✓  Layout set to \'{layout}\'.')
        else:
            st.set_text(f'Failed: {result.stderr.strip()}')

    b.pack_start(searchable_list(keymaps, apply_layout), True, True, 0)
    b.pack_start(st, False, False, 0)
    return s

def page_power():
    s, b = page_box()
    b.pack_start(page_title('Power Management', 'Configure idle timeouts for lock and display'), False, False, 0)

    def spin_row(label, desc, val, key):
        spin = Gtk.SpinButton.new_with_range(30, 7200, 30)
        spin.set_value(int(val)); spin.set_size_request(90, -1)
        suf = Gtk.Label(label='sec'); suf.get_style_context().add_class('dim')
        save = btn('Save', (lambda k, sp: lambda: conf_set(AUTOSTART, k, str(int(sp.get_value()))))(key, spin))
        hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        vb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        vb.pack_start(Gtk.Label(label=label, xalign=0), False, False, 0)
        d = Gtk.Label(label=desc, xalign=0); d.get_style_context().add_class('dim')
        vb.pack_start(d, False, False, 0)
        hb.pack_start(vb, True, True, 0)
        hb.pack_end(save, False, False, 0)
        hb.pack_end(suf, False, False, 0)
        hb.pack_end(spin, False, False, 0)
        return hb

    c = card()
    c.pack_start(spin_row('Lock screen after',
        'Seconds of idle before locking', conf_get(AUTOSTART, 'IDLE_LOCK', '300'), 'IDLE_LOCK'), False, False, 0)
    c.pack_start(hsep(), False, False, 0)
    c.pack_start(spin_row('Display off after',
        'Seconds of idle before turning display off', conf_get(AUTOSTART, 'IDLE_DPMS', '600'), 'IDLE_DPMS'), False, False, 0)
    b.pack_start(c, False, False, 0)
    note = status_label('Changes apply on next login.')
    b.pack_start(note, False, False, 0)
    return s

def page_datetime():
    s, b = page_box()
    b.pack_start(page_title('Date & Time', 'Set your timezone'), False, False, 0)

    cur_tz_m = re.search(r'Time zone:\s+(\S+)', _shell(['timedatectl', 'status']))
    cur_tz = cur_tz_m.group(1) if cur_tz_m else 'UTC'

    cur_lbl = Gtk.Label(label=f'Current timezone:  {cur_tz}', xalign=0)
    cur_lbl.get_style_context().add_class('dim')
    cur_lbl.set_margin_bottom(12)
    b.pack_start(cur_lbl, False, False, 0)

    try:
        tzones = _shell(['timedatectl', 'list-timezones']).splitlines()
    except Exception:
        tzones = ['UTC', 'America/New_York', 'Europe/London']

    st = status_label('Double-click a timezone to apply it.')

    def apply_tz(tz):
        if tz not in _shell(['timedatectl', 'list-timezones']).splitlines():
            st.set_text(f'Invalid timezone: {tz}'); return
        result = subprocess.run(['sudo', 'timedatectl', 'set-timezone', tz],
                                capture_output=True, text=True)
        if result.returncode == 0:
            cur_lbl.set_text(f'Current timezone:  {tz}')
            st.set_text(f'✓  Timezone set to \'{tz}\'.')
        else:
            st.set_text(f'Failed: {result.stderr.strip()}')

    b.pack_start(searchable_list(tzones, apply_tz), True, True, 0)
    b.pack_start(st, False, False, 0)
    return s

