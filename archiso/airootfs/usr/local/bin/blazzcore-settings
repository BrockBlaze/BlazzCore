    b.pack_start(page_title('Appearance', 'Colors, wallpaper, theme, icons, and fonts'), False, False, 0)
    c1 = card()
    c1.pack_start(row('Accent Color', 'Window border and highlight color',
        btn('Change', lambda: run_bg('blazzcore-accent'))), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)
    c1.pack_start(row('Wallpaper', 'Set the desktop background image',
        btn('Choose', lambda: run_bg('blazzcore-wallpaper'))), False, False, 0)
    b.pack_start(c1, False, False, 0)
    c2 = card()
    c2.pack_start(row('GTK Theme & Icons', 'Application theme, icon pack, cursor, and fonts',
        btn('Open', lambda: run_bg('nwg-look'))), False, False, 0)
    b.pack_start(c2, False, False, 0)
    return s

def page_dock():
    s, b = page_box()
    b.pack_start(page_title('Dock', 'Set the position of the application dock'), False, False, 0)
    c = card()
    positions = [
        ('Bottom', 'Place the dock at the bottom of the screen', 'bottom'),
        ('Left',   'Place the dock on the left side',            'left'),
        ('Right',  'Place the dock on the right side',           'right'),
        ('Top',    'Place the dock at the top of the screen',    'top'),
    ]
    for i, (label, desc, pos) in enumerate(positions):
        c.pack_start(row(label, desc,
            btn('Set', (lambda p: lambda: run_bg(f'blazzcore-dock {p}'))(pos))), False, False, 0)
        if i < len(positions) - 1:
            c.pack_start(hsep(), False, False, 0)
    b.pack_start(c, False, False, 0)
    return s

