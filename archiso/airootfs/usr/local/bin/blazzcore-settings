def page_about():
    s, b = page_box()
    b.pack_start(page_title('About BlazzCore'), False, False, 0)

    version  = _shell(['cat', '/etc/blazzcore-version']) or 'BlazzCore'
    kernel   = _shell(['uname', '-r'])
    pkg_cnt  = _shell('pacman -Q 2>/dev/null | wc -l') + ' packages'
    uptime   = _shell(['uptime', '-p'])

    c = card()
    for i, (k, v) in enumerate([
        ('Version',      version),
        ('Kernel',       kernel),
        ('Architecture', 'x86_64'),
        ('Packages',     pkg_cnt),
        ('Uptime',       uptime),
    ]):
        hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        kl = Gtk.Label(label=k, xalign=0); kl.set_size_request(160, -1)
        kl.get_style_context().add_class('dim')
        vl = Gtk.Label(label=v, xalign=0)
        hb.pack_start(kl, False, False, 0)
        hb.pack_start(vl, True, True, 0)
        c.pack_start(hb, False, False, 2)
        if i < 4:
            c.pack_start(hsep(), False, False, 0)
    b.pack_start(c, False, False, 0)
    return s

# ── Main window ───────────────────────────────────────────────────────────────
class SettingsApp(Gtk.Window):
    def __init__(self):
        super().__init__(title='BlazzCore Settings')
        self.set_default_size(900, 640)
        self.set_border_width(0)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.add(hbox)

        stack = Gtk.Stack()
        stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        stack.set_transition_duration(80)

        sidebar = Gtk.StackSidebar()
        sidebar.set_stack(stack)

        pages = [
            ('display',    '  Display',      page_display),
            ('appearance', '  Appearance',   page_appearance),
            ('dock',       '  Dock',         page_dock),
            ('sound',      '  Sound',        page_sound),
            ('bluetooth',  '  Bluetooth',    page_bluetooth),
            ('network',    '  Network',      page_network),
            ('nightlight', '  Night Light',  page_nightlight),
            ('keyboard',   '  Keyboard',     page_keyboard),
            ('power',      '  Power',        page_power),
            ('datetime',   '  Date & Time',  page_datetime),
            ('updates',    '  Updates',      page_updates),
            ('drivers',    '  Drivers',      page_drivers),
            ('software',   '  Software',     page_software),
            ('about',      '  About',        page_about),
        ]

        for name, label, builder in pages:
            stack.add_titled(builder(), name, label)

        hbox.pack_start(sidebar, False, False, 0)
        hbox.pack_start(Gtk.Separator(orientation=Gtk.Orientation.VERTICAL), False, False, 0)
        hbox.pack_start(stack, True, True, 0)


def main():
    win = SettingsApp()
    win.connect('destroy', Gtk.main_quit)
    win.show_all()
    Gtk.main()

if __name__ == '__main__':
    main()
