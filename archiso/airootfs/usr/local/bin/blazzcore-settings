# ── Helpers ───────────────────────────────────────────────────────────────────
def run_bg(cmd, status_lbl=None):
    exe = (cmd.split()[0] if isinstance(cmd, str) else cmd[0])
    if not shutil.which(exe):
        msg = f'Not installed: {exe}'
        if status_lbl:
            status_lbl.set_text(msg)
        else:
            try:
                subprocess.Popen(['notify-send', '-u', 'critical', 'Settings', msg])
            except Exception:
                pass
        return
    if status_lbl:
        status_lbl.set_text('Launching…')
    try:
        proc = subprocess.Popen(cmd, shell=isinstance(cmd, str))
    except Exception as e:
        if status_lbl:
            status_lbl.set_text(f'Error: {e}')
        return
    def _check_alive():
        rc = proc.poll()
        if rc is None:
            if status_lbl:
                status_lbl.set_text('✓  Opened.')
                GLib.timeout_add(2500, lambda: status_lbl.set_text('') or False)
        else:
            if status_lbl:
                status_lbl.set_text(f'Failed to launch {exe} (exit {rc}).')
        return False
    GLib.timeout_add(1000, _check_alive)

def run_term(title, cmd, status_lbl=None):
    run_bg(f"foot --title='{title}' -e bash -c '{cmd}; echo; echo \"Press Enter to close...\"; read'",
           status_lbl)

def themerc_get(path, key, default=''):
    try:
        for line in open(path):
            s = line.strip()
            if s.startswith(f'{key}:'):
                return s.split(':', 1)[1].strip()
    except FileNotFoundError:
        pass
    return default

def themerc_set(path, key, value):
    try:
        lines = open(path).readlines()
    except FileNotFoundError:
        lines = []
    found = False
    for i, l in enumerate(lines):
        if l.strip().startswith(f'{key}:'):
            lines[i] = f'{key}:             {value}\n'
            found = True
            break
    if not found:
        lines.append(f'{key}:             {value}\n')
    os.makedirs(os.path.dirname(path), exist_ok=True)
    open(path, 'w').writelines(lines)

def conf_get(path, key, default=''):
    try:
        for line in open(path):
            m = re.match(rf'^{key}=(.+)', line.strip())
            if m:
                val = m.group(1).strip('"\'')
                val = val.split('#')[0].strip()
                return val
    except FileNotFoundError:
        pass
    return default

def conf_set(path, key, value):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    try:
        lines = open(path).readlines()
    except FileNotFoundError:
        lines = []
    found = False
    for i, l in enumerate(lines):
        if l.startswith(f'{key}='):
            lines[i] = f'{key}={value}\n'; found = True; break
    if not found:
        lines.append(f'{key}={value}\n')
    open(path, 'w').writelines(lines)

def _shell(cmd):
    try:
        return subprocess.check_output(cmd, text=True,
               stderr=subprocess.DEVNULL, shell=isinstance(cmd, str)).strip()
    except Exception:
        return ''

def _gsettings_get(schema, key, default=''):
    out = _shell(f'gsettings get {schema} {key} 2>/dev/null')
    return out.strip("'") if out else default

def _gsettings_set(schema, key, value):
    subprocess.Popen(['gsettings', 'set', schema, key, value])

# ── Page building primitives ──────────────────────────────────────────────────
def page_box():
    scroll = Gtk.ScrolledWindow()
    scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    vbox.set_border_width(30)
    scroll.add(vbox)
    return scroll, vbox

def page_title(text, sub=None):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    t = Gtk.Label(label=text, xalign=0)
    t.get_style_context().add_class('page-title')
    box.pack_start(t, False, False, 0)
    if sub:
        s = Gtk.Label(label=sub, xalign=0)
        s.get_style_context().add_class('subtitle')
        box.pack_start(s, False, False, 0)
    sep = Gtk.Separator()
    sep.set_margin_top(12); sep.set_margin_bottom(16)
    box.pack_start(sep, False, False, 0)
    return box

def card():
    b = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    b.get_style_context().add_class('card')
    return b

def row(label, desc=None, widget=None):
    hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    hb.set_margin_top(2); hb.set_margin_bottom(2)
    vb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    vb.pack_start(Gtk.Label(label=label, xalign=0), False, False, 0)
    if desc:
        d = Gtk.Label(label=desc, xalign=0)
        d.get_style_context().add_class('dim')
        vb.pack_start(d, False, False, 0)
    hb.pack_start(vb, True, True, 0)
    if widget:
        widget.set_valign(Gtk.Align.CENTER)
        hb.pack_end(widget, False, False, 0)
    return hb

def btn(label, cb, css='action'):
    b = Gtk.Button(label=label)
    if css:
        b.get_style_context().add_class(css)
    b.connect('clicked', lambda _: cb())
    return b

def hsep():
    s = Gtk.Separator()
    s.set_margin_top(2); s.set_margin_bottom(2)
    return s

def status_label(text=''):
    l = Gtk.Label(label=text, xalign=0)
    l.get_style_context().add_class('dim')
    l.set_margin_top(6)
    return l

def searchable_list(items, on_activate):
    vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    search = Gtk.SearchEntry()
    search.set_placeholder_text('Search...')
    scroll = Gtk.ScrolledWindow()
    scroll.set_size_request(-1, 290)
    scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    lb = Gtk.ListBox()
    lb.set_selection_mode(Gtk.SelectionMode.SINGLE)
    lb.set_activate_on_single_click(True)
    for item in items:
        r = Gtk.ListBoxRow()
        l = Gtk.Label(label=item, xalign=0)
        l.set_margin_start(8); l.set_margin_top(3); l.set_margin_bottom(3)
        r.add(l)
        lb.add(r)
    def _filter(row, _=None):
        q = search.get_text().lower()
        return not q or q in row.get_child().get_text().lower()
    lb.set_filter_func(_filter)
    search.connect('search-changed', lambda _: lb.invalidate_filter())
    lb.connect('row-activated', lambda lb, r: on_activate(r.get_child().get_text()))
    scroll.add(lb)
    vbox.pack_start(search, False, False, 0)
    vbox.pack_start(scroll, True, True, 0)
    return vbox

def themed_combo(items, current, on_change):
    cb = Gtk.ComboBoxText()
    cur_idx = 0
    for i, item in enumerate(items):
        cb.append_text(item)
        if item == current:
            cur_idx = i
    cb.set_active(cur_idx)
    cb.connect('changed', lambda c: on_change(c.get_active_text()) if c.get_active_text() else None)
    return cb

# ── Pages ─────────────────────────────────────────────────────────────────────
def page_display():
    s, b = page_box()
    b.pack_start(page_title('Display & Monitors',
        'Configure resolution and refresh rate'), False, False, 0)
    st = status_label()

    def get_display_info():
        raw = _shell(['wlr-randr'])
        outputs = []
        cur = None
        for line in raw.splitlines():
            if line and not line[0].isspace():
                name = line.split()[0]
                cur = {'name': name, 'modes': [], 'current': None}
                outputs.append(cur)
            elif cur is not None:
                m = re.match(r'\s+(\d+x\d+)\s+px,\s+([\d.]+)\s+Hz(.*)', line)
                if m:
                    res, hz, flags = m.group(1), float(m.group(2)), m.group(3)
                    mode = {'res': res, 'hz': hz, 'label': f'{res} @ {hz:.0f} Hz'}
                    if 'current' in flags:
                        cur['current'] = mode
                    cur['modes'].append(mode)
        return outputs

    outputs = get_display_info()

    if not outputs:
        c = card()
        c.pack_start(row('No displays detected',
            'wlr-randr found no connected outputs — are you running a Wayland session?'), False, False, 0)
        b.pack_start(c, False, False, 0)
        b.pack_start(st, False, False, 0)
        return s

    for output in outputs:
        c = card()
        name_lbl = Gtk.Label(label=output['name'], xalign=0)
        name_lbl.get_style_context().add_class('page-title')
        name_lbl.set_margin_bottom(6)
        c.pack_start(name_lbl, False, False, 0)
        modes = output['modes']
        if modes:
            combo = Gtk.ComboBoxText()
            cur_idx = 0
            for i, mode in enumerate(modes):
                combo.append_text(mode['label'])
                if output['current'] and mode['label'] == output['current']['label']:
                    cur_idx = i
            combo.set_active(cur_idx)
            def _apply(combo=combo, out=output, modes=modes):
                idx = combo.get_active()
                if idx < 0: return
                mode = modes[idx]
                result = subprocess.run(
                    ['wlr-randr', '--output', out['name'],
                     '--mode', f"{mode['res']}@{mode['hz']:.6f}Hz"],
                    capture_output=True, text=True)
                if result.returncode == 0:
                    st.set_text(f"✓  {out['name']} set to {mode['label']}")
                else:
                    err = result.stderr.strip() or f"exit {result.returncode}"
                    st.set_text(f"Failed: {err}")
                GLib.timeout_add(3000, lambda: st.set_text('') or False)
            hb = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            hb.pack_start(combo, True, True, 0)
            hb.pack_start(btn('Apply', _apply), False, False, 0)
            c.pack_start(row('Resolution & Refresh Rate',
                'Select from available modes for this display', None), False, False, 0)
            c.pack_start(hb, False, False, 6)
        else:
            c.pack_start(row('No modes available', 'This output reported no supported modes'), False, False, 0)
        b.pack_start(c, False, False, 0)

    b.pack_start(st, False, False, 0)
    return s

def page_appearance():
    s, b = page_box()
    b.pack_start(page_title('Appearance', 'Colors, wallpaper, theme, and icons'), False, False, 0)
    st = status_label()

    SYS_THEMERC  = '/usr/share/themes/BlazzCore/openbox-3/themerc'
    # Write to both paths: ~/.local/share is the standard theme search path;
    # ~/.config/labwc/themerc is the override path for labwc 0.7+
    USER_THEMERC = os.path.expanduser('~/.local/share/themes/BlazzCore/openbox-3/themerc')
    CFG_THEMERC  = os.path.expanduser('~/.config/labwc/themerc')

    cur_hex = (themerc_get(USER_THEMERC, 'window.active.border.color') or
               themerc_get(CFG_THEMERC,  'window.active.border.color') or
               themerc_get(SYS_THEMERC,  'window.active.border.color') or '#4a4a8a')
    rgba = Gdk.RGBA()
    if not rgba.parse(cur_hex):
        rgba.parse('#4a4a8a')

    color_btn = Gtk.ColorButton.new_with_rgba(rgba)
    color_btn.set_use_alpha(False)
    color_btn.set_title('Choose Accent Color')

    def _on_color_set(button):
        c = button.get_rgba()
        r, g, bl = int(c.red * 255), int(c.green * 255), int(c.blue * 255)
        accent = f'#{r:02x}{g:02x}{bl:02x}'
        title  = f'#{int(r*.20):02x}{int(g*.20):02x}{int(bl*.20):02x}'
        for path in (USER_THEMERC, CFG_THEMERC):
            if not os.path.exists(path):
                try:
                    os.makedirs(os.path.dirname(path), exist_ok=True)
                    shutil.copy(SYS_THEMERC, path)
                except Exception:
                    pass
            themerc_set(path, 'window.active.border.color',   accent)
            themerc_set(path, 'window.active.title.bg.color', title)
        try:
            subprocess.Popen(['labwc', '--reconfigure'])
        except Exception:
            try:
                subprocess.run(['pkill', '-SIGUSR1', 'labwc'], capture_output=True)
            except Exception:
                pass
        # Save accent for other BlazzCore apps (start menu, etc.)
        accent_dir = os.path.expanduser('~/.config/blazzcore')
        os.makedirs(accent_dir, exist_ok=True)
        with open(os.path.join(accent_dir, 'accent'), 'w') as af:
            af.write(accent + '\n')
        st.set_text(f'✓  Accent set to {accent}.')
        GLib.timeout_add(2500, lambda: st.set_text('') or False)

    color_btn.connect('color-set', _on_color_set)

    c1 = card()
    c1.pack_start(row('Accent Color', 'Window border and highlight color', color_btn), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)

    # Wallpaper: image picker + color gradient generator
    wp_box = Gtk.Box(spacing=8)
    wp_img_btn = btn('Image', lambda: run_bg('blazzcore-wallpaper', st))
    wp_box.pack_start(wp_img_btn, False, False, 0)

    wp_color_btn = Gtk.ColorButton()
    wp_color_btn.set_use_alpha(False)
    wp_color_btn.set_title('Choose Wallpaper Color')
    wp_rgba = Gdk.RGBA()
    wp_rgba.parse('#0a1e50')
    wp_color_btn.set_rgba(wp_rgba)

    def _on_wallpaper_color(button):
        c = button.get_rgba()
        r, g, bl = int(c.red * 255), int(c.green * 255), int(c.blue * 255)
        hex_c = f'#{r:02x}{g:02x}{bl:02x}'
        st.set_text('Generating wallpaper...')
        def _gen():
            try:
                subprocess.run([
                    '/usr/local/bin/blazzcore-gen-wallpapers', '--color', hex_c
                ], capture_output=True, timeout=60)
                wp_path = os.path.expanduser('~/.local/share/backgrounds/blazzcore/custom.png')
                subprocess.Popen(['pkill', 'swaybg'])
                import time; time.sleep(0.3)
                subprocess.Popen(['swaybg', '-i', wp_path, '-m', 'fill'])
                GLib.idle_add(lambda: st.set_text(f'✓  Wallpaper set to {hex_c} gradient.') or False)
                GLib.timeout_add(2500, lambda: st.set_text('') or False)
            except Exception as e:
                GLib.idle_add(lambda: st.set_text(f'Error: {e}') or False)
        threading.Thread(target=_gen, daemon=True).start()

    wp_color_btn.connect('color-set', _on_wallpaper_color)
    wp_box.pack_start(wp_color_btn, False, False, 0)

    c1.pack_start(row('Wallpaper', 'Pick an image or generate a color gradient', wp_box), False, False, 0)
    b.pack_start(c1, False, False, 0)

    # GTK theme / icon / cursor — inline, no nwg-look
    def get_themes():
        themes = []
        for d in ['/usr/share/themes',
                  os.path.expanduser('~/.local/share/themes'),
                  os.path.expanduser('~/.themes')]:
            try:
                for t in sorted(os.listdir(d)):
                    if os.path.exists(os.path.join(d, t, 'gtk-3.0')):
                        themes.append(t)
            except FileNotFoundError:
                pass
        return sorted(set(themes)) or ['Adwaita-dark']

    def get_icon_themes():
        icons = []
        for d in ['/usr/share/icons',
                  os.path.expanduser('~/.local/share/icons'),
                  os.path.expanduser('~/.icons')]:
            try:
                for t in sorted(os.listdir(d)):
                    if os.path.exists(os.path.join(d, t, 'index.theme')):
                        icons.append(t)
            except FileNotFoundError:
                pass
        return sorted(set(icons)) or ['Papirus-Dark']

    cur_theme  = _gsettings_get('org.gnome.desktop.interface', 'gtk-theme',    'Adwaita-dark')
    cur_icons  = _gsettings_get('org.gnome.desktop.interface', 'icon-theme',   'Papirus-Dark')
    cur_cursor = _gsettings_get('org.gnome.desktop.interface', 'cursor-theme', 'Adwaita')

    themes  = get_themes()
    icons   = get_icon_themes()
    cursors = [t for t in icons if 'cursor' in t.lower() or os.path.exists(f'/usr/share/icons/{t}/cursors')] \
              or ['Adwaita']

    c2 = card()
    c2.pack_start(row('GTK Theme', 'Application window style',
        themed_combo(themes, cur_theme,
            lambda v: (_gsettings_set('org.gnome.desktop.interface', 'gtk-theme', v),
                       st.set_text(f'✓  Theme: {v}'),
                       GLib.timeout_add(2500, lambda: st.set_text('') or False))
        )), False, False, 0)
    c2.pack_start(hsep(), False, False, 0)
    c2.pack_start(row('Icon Theme', 'Application and desktop icons',
        themed_combo(icons, cur_icons,
            lambda v: (_gsettings_set('org.gnome.desktop.interface', 'icon-theme', v),
                       st.set_text(f'✓  Icons: {v}'),
                       GLib.timeout_add(2500, lambda: st.set_text('') or False))
        )), False, False, 0)
    c2.pack_start(hsep(), False, False, 0)
    c2.pack_start(row('Cursor Theme', 'Mouse pointer style',
        themed_combo(cursors, cur_cursor,
            lambda v: (_gsettings_set('org.gnome.desktop.interface', 'cursor-theme', v),
                       st.set_text(f'✓  Cursor: {v}'),
                       GLib.timeout_add(2500, lambda: st.set_text('') or False))
        )), False, False, 0)
    b.pack_start(c2, False, False, 0)

    b.pack_start(st, False, False, 0)
    return s

def page_taskbar():
    s, b = page_box()
    b.pack_start(page_title('Taskbar', 'Restart or configure the Waybar taskbar'), False, False, 0)
    st = status_label()
    def restart_waybar():
        subprocess.run(['pkill', 'waybar'], capture_output=True)
        subprocess.Popen(['waybar'])
        st.set_text('✓  Waybar restarted.')
    c = card()
    c.pack_start(row('Restart Taskbar', 'Apply config changes by restarting waybar',
        btn('Restart', restart_waybar)), False, False, 0)
    b.pack_start(c, False, False, 0)
    b.pack_start(st, False, False, 0)
    return s

def page_sound():
    s, b = page_box()
    b.pack_start(page_title('Sound', 'Volume and audio output'), False, False, 0)
    st = status_label()

    # ── Output volume card (built immediately with placeholder values) ──
    c1 = card()

    vol_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
    vol_scale.set_value(50)
    vol_scale.set_draw_value(False)
    vol_scale.set_size_request(220, -1)
    vol_pct = Gtk.Label(label='—')
    vol_pct.set_size_request(42, -1)
    vol_pct.set_xalign(1)

    def on_vol(scale):
        v = int(scale.get_value())
        vol_pct.set_text(f'{v}%')
        subprocess.Popen(['wpctl', 'set-volume', '@DEFAULT_AUDIO_SINK@', f'{v}%'])

    vol_scale.connect('value-changed', on_vol)

    vol_box = Gtk.Box(spacing=8)
    vol_box.pack_start(vol_scale, True, True, 0)
    vol_box.pack_start(vol_pct, False, False, 0)

    c1.pack_start(row('Output Volume', 'Master audio level', None), False, False, 0)
    c1.pack_start(vol_box, False, False, 4)
    c1.pack_start(hsep(), False, False, 0)

    mute_sw = Gtk.Switch()
    mute_sw.set_active(False)
    _mute_handler = [None]

    def on_mute(sw, _):
        subprocess.Popen(['wpctl', 'set-mute', '@DEFAULT_AUDIO_SINK@', 'toggle'])

    _mute_handler[0] = mute_sw.connect('notify::active', on_mute)
    c1.pack_start(row('Mute Output', 'Silence all audio output', mute_sw), False, False, 0)
    b.pack_start(c1, False, False, 0)

    # ── Output device card ──
    c2 = card()
    combo = Gtk.ComboBoxText()
    combo.append_text('Detecting…')
    combo.set_active(0)
    combo.set_sensitive(False)
    _sinks = []

    def on_sink(c):
        idx = c.get_active()
        if 0 <= idx < len(_sinks):
            subprocess.Popen(['pactl', 'set-default-sink', _sinks[idx]])
            st.set_text('✓  Output device changed.')
            GLib.timeout_add(2500, lambda: st.set_text('') or False)

    combo.connect('changed', on_sink)
    c2.pack_start(row('Output Device', 'Select audio output', combo), False, False, 0)
    b.pack_start(c2, False, False, 0)

    # ── Microphone card ──
    c3 = card()
    mic_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
    mic_scale.set_value(80)
    mic_scale.set_draw_value(False)
    mic_scale.set_size_request(220, -1)
    mic_pct = Gtk.Label(label='—')
    mic_pct.set_size_request(42, -1)
    mic_pct.set_xalign(1)

    def on_mic(scale):
        v = int(scale.get_value())
        mic_pct.set_text(f'{v}%')
        subprocess.Popen(['wpctl', 'set-volume', '@DEFAULT_AUDIO_SOURCE@', f'{v}%'])

    mic_scale.connect('value-changed', on_mic)
    mic_box = Gtk.Box(spacing=8)
    mic_box.pack_start(mic_scale, True, True, 0)
    mic_box.pack_start(mic_pct, False, False, 0)
    c3.pack_start(row('Microphone', 'Input capture level', None), False, False, 0)
    c3.pack_start(mic_box, False, False, 4)
    b.pack_start(c3, False, False, 0)

    b.pack_start(st, False, False, 0)

    # ── Background thread: fetch audio data then update widgets ──
    def _fetch():
        def _t(cmd):
            try:
                return subprocess.check_output(
                    cmd, text=True, stderr=subprocess.DEVNULL,
                    shell=isinstance(cmd, str), timeout=4
                ).strip()
            except Exception:
                return ''

        out   = _t(['wpctl', 'get-volume', '@DEFAULT_AUDIO_SINK@'])
        m     = re.search(r'Volume:\s*([\d.]+)(\s+\[MUTED\])?', out)
        vol   = min(100, int(float(m.group(1)) * 100)) if m else 50
        muted = m is not None and m.group(2) is not None

        sinks_raw    = _t('pactl list short sinks 2>/dev/null')
        sinks        = [ln.split('\t')[1] for ln in sinks_raw.splitlines()
                        if len(ln.split('\t')) >= 2]
        default_sink = _t('pactl get-default-sink 2>/dev/null') if sinks else ''

        mic_raw = _t(['wpctl', 'get-volume', '@DEFAULT_AUDIO_SOURCE@'])
        mic_m   = re.search(r'Volume:\s*([\d.]+)', mic_raw)
        mic_vol = min(100, int(float(mic_m.group(1)) * 100)) if mic_m else 80

        def _update():
            vol_scale.handler_block_by_func(on_vol)
            vol_scale.set_value(vol)
            vol_scale.handler_unblock_by_func(on_vol)
            vol_pct.set_text(f'{vol}%')

            mute_sw.handler_block(_mute_handler[0])
            mute_sw.set_active(muted)
            mute_sw.handler_unblock(_mute_handler[0])

            _sinks.clear()
            _sinks.extend(sinks)
            combo.remove(0)  # remove "Detecting…"
            if sinks:
                friendly = [sk.replace('alsa_output.', '').replace('_', ' ').strip()
                            for sk in sinks]
                cur = 0
                for i, (sk, f) in enumerate(zip(sinks, friendly)):
                    combo.append_text(f or sk)
                    if sk == default_sink:
                        cur = i
                combo.set_active(cur)
                combo.set_sensitive(True)
            else:
                combo.append_text('No devices found')
                combo.set_active(0)

            mic_scale.handler_block_by_func(on_mic)
            mic_scale.set_value(mic_vol)
            mic_scale.handler_unblock_by_func(on_mic)
            mic_pct.set_text(f'{mic_vol}%')
            return False

        GLib.idle_add(_update)

    threading.Thread(target=_fetch, daemon=True).start()
    return s

def page_network():
    s, b = page_box()
    b.pack_start(page_title('Network', 'Wi-Fi and wired connections'), False, False, 0)
    st = status_label()

    def wifi_on():
        return 'enabled' in _shell('nmcli radio wifi 2>/dev/null').lower()

    def active_conn():
        out = _shell('nmcli -t -f NAME,TYPE,STATE connection show --active 2>/dev/null')
        for line in out.splitlines():
            parts = line.split(':')
            if len(parts) >= 3 and 'activated' in parts[2]:
                return parts[0]
        return None

    # WiFi on/off card
    c1 = card()
    is_on = wifi_on()
    wifi_sw = Gtk.Switch()
    wifi_sw.set_active(is_on)

    conn_name = active_conn()
    conn_lbl = Gtk.Label(
        label=f'Connected: {conn_name}' if conn_name else 'Not connected', xalign=0)
    conn_lbl.get_style_context().add_class('dim')

    net_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    net_box.set_margin_top(6)

    def connect_to(ssid, secured, window):
        if secured:
            dialog = Gtk.Dialog(title=f'Connect to {ssid}', transient_for=window, flags=0)
            dialog.add_buttons('Connect', Gtk.ResponseType.OK, 'Cancel', Gtk.ResponseType.CANCEL)
            area = dialog.get_content_area()
            area.set_margin_start(20); area.set_margin_end(20)
            area.set_margin_top(16); area.set_margin_bottom(8); area.set_spacing(10)
            area.pack_start(Gtk.Label(label=f'Password for "{ssid}":', xalign=0), False, False, 0)
            pw = Gtk.Entry()
            pw.set_visibility(False)
            pw.set_input_purpose(Gtk.InputPurpose.PASSWORD)
            pw.set_placeholder_text('Wi-Fi password')
            area.pack_start(pw, False, False, 0)
            area.show_all()
            resp = dialog.run()
            password = pw.get_text()
            dialog.destroy()
            if resp != Gtk.ResponseType.OK or not password:
                return
            cmd = ['nmcli', 'device', 'wifi', 'connect', ssid, 'password', password]
        else:
            cmd = ['nmcli', 'device', 'wifi', 'connect', ssid]

        st.set_text(f'Connecting to {ssid}...')

        def _run():
            result = subprocess.run(cmd, capture_output=True, text=True)
            def _done():
                if result.returncode == 0:
                    conn_lbl.set_text(f'Connected: {ssid}')
                    st.set_text(f'✓  Connected to {ssid}.')
                else:
                    err = result.stderr.strip() or 'Connection failed'
                    st.set_text(f'Failed: {err}')
                GLib.timeout_add(3000, lambda: st.set_text('') or False)
                refresh_nets()
            GLib.idle_add(_done)

        threading.Thread(target=_run, daemon=True).start()

    def refresh_nets():
        for child in net_box.get_children():
            net_box.remove(child)
        loading = Gtk.Label(label='Scanning...', xalign=0)
        loading.get_style_context().add_class('dim')
        net_box.pack_start(loading, False, False, 0)
        net_box.show_all()

        def _load():
            raw = _shell('nmcli -t -f IN-USE,SSID,SIGNAL,SECURITY device wifi list 2>/dev/null')
            nets = []
            seen = set()
            for line in raw.splitlines():
                parts = line.split(':')
                if len(parts) < 4:
                    continue
                in_use = parts[0] == '*'
                ssid = parts[1]
                if not ssid or ssid in seen:
                    continue
                seen.add(ssid)
                try:
                    signal = int(parts[2])
                except ValueError:
                    signal = 0
                secured = bool(parts[3] and parts[3] not in ('--', ''))
                nets.append((in_use, ssid, signal, secured))
            nets.sort(key=lambda x: (not x[0], -x[2]))

            def _populate():
                for child in net_box.get_children():
                    net_box.remove(child)
                window = s.get_toplevel()
                for in_use, ssid, signal, secured in nets[:25]:
                    hb = Gtk.Box(spacing=8)
                    hb.set_margin_top(1); hb.set_margin_bottom(1)
                    bars = '▂▄▆█'[: max(1, signal // 26)]
                    lock = '  🔒' if secured else ''
                    prefix = '✓  ' if in_use else '      '
                    lbl = Gtk.Label(label=f'{prefix}{ssid}{lock}', xalign=0)
                    sig_lbl = Gtk.Label(label=bars)
                    sig_lbl.get_style_context().add_class('dim')
                    hb.pack_start(lbl, True, True, 0)
                    hb.pack_start(sig_lbl, False, False, 0)
                    if not in_use:
                        cb = btn('Connect',
                            (lambda s2=ssid, sec=secured, w=window:
                             lambda: connect_to(s2, sec, w))(),
                            None)
                        hb.pack_end(cb, False, False, 0)
                    net_box.pack_start(hb, False, False, 0)
                if not nets:
                    lbl = Gtk.Label(label='No networks found — click Refresh', xalign=0)
                    lbl.get_style_context().add_class('dim')
                    net_box.pack_start(lbl, False, False, 0)
                net_box.show_all()
            GLib.idle_add(_populate)

        threading.Thread(target=_load, daemon=True).start()

    def on_wifi_toggle(sw, _):
        on = sw.get_active()
        subprocess.Popen(['nmcli', 'radio', 'wifi', 'on' if on else 'off'])
        if on:
            GLib.timeout_add(1200, lambda: refresh_nets() or False)

    wifi_sw.connect('notify::active', on_wifi_toggle)
    c1.pack_start(row('Wi-Fi', 'Enable wireless networking', wifi_sw), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)
    c1.pack_start(conn_lbl, False, False, 2)
    b.pack_start(c1, False, False, 0)

    # Network list card
    c2 = card()
    hdr = Gtk.Box(spacing=8)
    hdr.pack_start(Gtk.Label(label='Available Networks', xalign=0), True, True, 0)
    hdr.pack_end(btn('Refresh', refresh_nets, None), False, False, 0)
    c2.pack_start(hdr, False, False, 0)
    c2.pack_start(net_box, False, False, 0)
    b.pack_start(c2, False, False, 0)
    b.pack_start(st, False, False, 0)

    if is_on:
        GLib.idle_add(refresh_nets)

    return s

def page_bluetooth():
    s, b = page_box()
    b.pack_start(page_title('Bluetooth', 'Pair and manage Bluetooth devices'), False, False, 0)
    st = status_label()

    def bt_on():
        return 'yes' in _shell('bluetoothctl show 2>/dev/null | grep -i "powered:"').lower()

    c1 = card()
    is_on = bt_on()
    bt_sw = Gtk.Switch()
    bt_sw.set_active(is_on)

    devices_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)

    def refresh_devices():
        for child in devices_box.get_children():
            devices_box.remove(child)

        paired_raw = _shell('bluetoothctl devices Paired 2>/dev/null')
        conn_raw   = _shell('bluetoothctl devices Connected 2>/dev/null')
        conn_macs  = set(re.findall(r'([0-9A-Fa-f:]{17})', conn_raw))

        rows = 0
        for line in paired_raw.splitlines():
            m = re.match(r'Device ([0-9A-Fa-f:]{17}) (.+)', line)
            if not m:
                continue
            mac, name = m.group(1), m.group(2)
            connected = mac in conn_macs
            hb = Gtk.Box(spacing=8)
            hb.set_margin_top(2); hb.set_margin_bottom(2)
            dot = '●' if connected else '○'
            lbl = Gtk.Label(label=f'{dot}  {name}', xalign=0)
            hb.pack_start(lbl, True, True, 0)
            if connected:
                db = btn('Disconnect', (lambda m2=mac: lambda: (
                    subprocess.Popen(['bluetoothctl', 'disconnect', m2]),
                    st.set_text('Disconnecting...'),
                    GLib.timeout_add(2000, lambda: refresh_devices() or st.set_text('') or False)
                ))(), None)
                hb.pack_end(db, False, False, 0)
            else:
                cb = btn('Connect', (lambda m2=mac, n=name: lambda: (
                    subprocess.Popen(['bluetoothctl', 'connect', m2]),
                    st.set_text(f'Connecting to {n}...'),
                    GLib.timeout_add(4000, lambda: refresh_devices() or st.set_text('') or False)
                ))(), 'action')
                hb.pack_end(cb, False, False, 0)
            devices_box.pack_start(hb, False, False, 0)
            rows += 1

        if rows == 0:
            lbl = Gtk.Label(label='No paired devices', xalign=0)
            lbl.get_style_context().add_class('dim')
            devices_box.pack_start(lbl, False, False, 0)

        devices_box.show_all()

    _scan_proc = [None]

    def scan():
        if _scan_proc[0] and _scan_proc[0].poll() is None:
            return
        st.set_text('Scanning for 10 seconds...')
        _scan_proc[0] = subprocess.Popen(
            ['bluetoothctl', 'scan', 'on'],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

        def _stop():
            if _scan_proc[0] and _scan_proc[0].poll() is None:
                _scan_proc[0].terminate()
            subprocess.Popen(['bluetoothctl', 'scan', 'off'],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            refresh_devices()
            st.set_text('Scan complete.')
            GLib.timeout_add(2500, lambda: st.set_text('') or False)
            return False

        GLib.timeout_add(10000, _stop)

    def on_bt_toggle(sw, _):
        on = sw.get_active()
        subprocess.Popen(['bluetoothctl', 'power', 'on' if on else 'off'])
        if on:
            GLib.timeout_add(1000, lambda: refresh_devices() or False)

    bt_sw.connect('notify::active', on_bt_toggle)
    c1.pack_start(row('Bluetooth', 'Enable Bluetooth radio', bt_sw), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)
    c1.pack_start(row('Scan for Devices', 'Discover nearby Bluetooth devices',
        btn('Scan (10s)', scan)), False, False, 0)
    b.pack_start(c1, False, False, 0)

    c2 = card()
    c2.pack_start(Gtk.Label(label='Paired Devices', xalign=0), False, False, 2)
    c2.pack_start(devices_box, False, False, 0)
    b.pack_start(c2, False, False, 0)

    if is_on:
        GLib.idle_add(refresh_devices)

    b.pack_start(st, False, False, 0)
    return s

def page_nightlight():
    s, b = page_box()
    b.pack_start(page_title('Night Light', 'Reduce blue light with warm color temperature'), False, False, 0)

    c1 = card()
    is_on = subprocess.run(['pgrep', '-x', 'wlsunset'], capture_output=True).returncode == 0
    sw = Gtk.Switch()
    sw.set_active(is_on)

    def _toggle(sw, _):
        run_bg('blazzcore-nightlight')
        def _resync():
            actual = subprocess.run(['pgrep', '-x', 'wlsunset'], capture_output=True).returncode == 0
            sw.handler_block_by_func(_toggle)
            sw.set_active(actual)
            sw.handler_unblock_by_func(_toggle)
            return False
        GLib.timeout_add(600, _resync)

    sw.connect('notify::active', _toggle)
    c1.pack_start(row('Enable Night Light', 'Reduce eye strain by warming the screen color', sw), False, False, 0)
    b.pack_start(c1, False, False, 0)

    c2 = card()
    night_t = int(conf_get(NL_CONF, 'NIGHT_TEMP', '3500'))
    day_t   = int(conf_get(NL_CONF, 'DAY_TEMP',   '6500'))

    def temp_row(label, val, lo, hi, key):
        hb = Gtk.Box(spacing=10)
        lbl = Gtk.Label(label=label, xalign=0)
        lbl.set_size_request(140, -1)
        sc = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, lo, hi, 100)
        sc.set_value(val); sc.set_draw_value(False); sc.set_size_request(200, -1)
        vl = Gtk.Label(label=f'{val}K'); vl.set_size_request(55, -1)
        def on_change(sc, vl=vl, k=key):
            v = int(sc.get_value()); vl.set_text(f'{v}K'); conf_set(NL_CONF, k, str(v))
        sc.connect('value-changed', on_change)
        hb.pack_start(lbl, False, False, 0)
        hb.pack_start(sc, True, True, 0)
        hb.pack_start(vl, False, False, 0)
        return hb

    c2.pack_start(temp_row('Night (warm)', night_t, 1000, 6500,  'NIGHT_TEMP'), False, False, 0)
    c2.pack_start(hsep(), False, False, 0)
    c2.pack_start(temp_row('Day (cool)',   day_t,   3000, 10000, 'DAY_TEMP'),   False, False, 0)
    b.pack_start(c2, False, False, 0)
    return s

def page_keyboard():
    s, b = page_box()
    b.pack_start(page_title('Keyboard', 'Set your keyboard input layout'), False, False, 0)

    m = re.search(r'VC Keymap:\s+(\S+)', _shell(['localectl', 'status']))
    cur_layout = m.group(1) if m else 'us'

    cur_lbl = Gtk.Label(label=f'Current layout:  {cur_layout}', xalign=0)
    cur_lbl.get_style_context().add_class('dim')
    cur_lbl.set_margin_bottom(12)
    b.pack_start(cur_lbl, False, False, 0)

    st = status_label('Loading keyboard layouts…')
    placeholder = Gtk.Label(label='Loading…', xalign=0)
    placeholder.get_style_context().add_class('dim')
    b.pack_start(placeholder, False, False, 0)
    b.pack_start(st, False, False, 0)

    def apply_layout(layout):
        result = subprocess.run(['sudo', 'localectl', 'set-keymap', layout],
                                capture_output=True, text=True)
        if result.returncode == 0:
            cur_lbl.set_text(f'Current layout:  {layout}')
            st.set_text(f'✓  Layout set to \'{layout}\'.')
        else:
            st.set_text(f'Failed: {result.stderr.strip()}')

    def load_keymaps():
        keymaps = _shell(['localectl', 'list-keymaps']).splitlines() or ['us', 'uk', 'de', 'fr', 'es']
        def populate():
            b.remove(placeholder)
            b.pack_start(searchable_list(keymaps, apply_layout), True, True, 0)
            b.reorder_child(st, -1)
            b.show_all()
            st.set_text('Click a layout to apply it.')
            return False
        GLib.idle_add(populate)

    threading.Thread(target=load_keymaps, daemon=True).start()
    return s

def page_power():
    s, b = page_box()
    b.pack_start(page_title('Power Management', 'Configure idle timeouts for lock and display'), False, False, 0)
    note = status_label()

    def save_and_apply(key, spin):
        conf_set(AUTOSTART, key, str(int(spin.get_value())))
        lock_val = conf_get(AUTOSTART, 'IDLE_LOCK', '300')
        dpms_val = conf_get(AUTOSTART, 'IDLE_DPMS', '600')
        subprocess.run(['pkill', 'swayidle'], capture_output=True)
        subprocess.Popen([
            'swayidle', '-w',
            'timeout', lock_val, 'blazzcore-lock',
            'timeout', dpms_val, 'wlopm --off "*"',
            'resume', 'wlopm --on "*"',
            'before-sleep', 'blazzcore-lock',
        ])
        note.set_text('✓  Applied.')
        GLib.timeout_add(2500, lambda: note.set_text('') or False)

    def spin_row(label, desc, val, key):
        spin = Gtk.SpinButton.new_with_range(30, 7200, 30)
        spin.set_value(int(val)); spin.set_size_request(90, -1)
        suf = Gtk.Label(label='sec'); suf.get_style_context().add_class('dim')
        save = btn('Save', (lambda k, sp: lambda: save_and_apply(k, sp))(key, spin))
        hb = Gtk.Box(spacing=8)
        vb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        vb.pack_start(Gtk.Label(label=label, xalign=0), False, False, 0)
        d = Gtk.Label(label=desc, xalign=0); d.get_style_context().add_class('dim')
        vb.pack_start(d, False, False, 0)
        hb.pack_start(vb, True, True, 0)
        hb.pack_end(save, False, False, 0)
        hb.pack_end(suf, False, False, 0)
        hb.pack_end(spin, False, False, 0)
        return hb

    c = card()
    c.pack_start(spin_row('Lock screen after',
        'Seconds of idle before locking', conf_get(AUTOSTART, 'IDLE_LOCK', '300'), 'IDLE_LOCK'), False, False, 0)
    c.pack_start(hsep(), False, False, 0)
    c.pack_start(spin_row('Display off after',
        'Seconds of idle before turning display off', conf_get(AUTOSTART, 'IDLE_DPMS', '600'), 'IDLE_DPMS'), False, False, 0)
    b.pack_start(c, False, False, 0)
    b.pack_start(note, False, False, 0)
    return s

def page_datetime():
    s, b = page_box()
    b.pack_start(page_title('Date & Time', 'Set your timezone'), False, False, 0)

    cur_tz_m = re.search(r'Time zone:\s+(\S+)', _shell(['timedatectl', 'status']))
    cur_tz = cur_tz_m.group(1) if cur_tz_m else 'UTC'

    cur_lbl = Gtk.Label(label=f'Current timezone:  {cur_tz}', xalign=0)
    cur_lbl.get_style_context().add_class('dim')
    cur_lbl.set_margin_bottom(12)
    b.pack_start(cur_lbl, False, False, 0)

    st = status_label('Loading timezones…')
    placeholder = Gtk.Label(label='Loading…', xalign=0)
    placeholder.get_style_context().add_class('dim')
    b.pack_start(placeholder, False, False, 0)
    b.pack_start(st, False, False, 0)

    tzones_set = set()

    def apply_tz(tz):
        if tzones_set and tz not in tzones_set:
            st.set_text(f'Invalid timezone: {tz}'); return
        result = subprocess.run(['sudo', 'timedatectl', 'set-timezone', tz],
                                capture_output=True, text=True)
        if result.returncode == 0:
            cur_lbl.set_text(f'Current timezone:  {tz}')
            st.set_text(f'✓  Timezone set to \'{tz}\'.')
        else:
            st.set_text(f'Failed: {result.stderr.strip()}')

    def load_tzones():
        tzones = _shell(['timedatectl', 'list-timezones']).splitlines() \
                 or ['UTC', 'America/New_York', 'Europe/London']
        tzones_set.update(tzones)
        def populate():
            b.remove(placeholder)
            b.pack_start(searchable_list(tzones, apply_tz), True, True, 0)
            b.reorder_child(st, -1)
            b.show_all()
            st.set_text('Click a timezone to apply it.')
            return False
        GLib.idle_add(populate)

    threading.Thread(target=load_tzones, daemon=True).start()
    return s

