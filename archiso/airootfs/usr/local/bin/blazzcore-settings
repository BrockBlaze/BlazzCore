def page_mouse():
    s, b = page_box()
    b.pack_start(page_title('Mouse & Touchpad', 'Pointer speed and scrolling behavior'), False, False, 0)
    st = status_label()

    LIBINPUT_CONF = '/etc/libinput-gestures.conf'
    LABWC_ENV = os.path.expanduser('~/.config/labwc/environment')

    c1 = card()

    # Pointer speed
    speed_scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, -1.0, 1.0, 0.1)
    cur_speed = _shell("gsettings get org.gnome.desktop.peripherals.mouse speed 2>/dev/null").strip() or '0.0'
    try:
        speed_scale.set_value(float(cur_speed))
    except ValueError:
        speed_scale.set_value(0.0)
    speed_scale.set_draw_value(True)
    speed_scale.set_size_request(250, -1)

    def on_speed(scale):
        v = round(scale.get_value(), 2)
        _gsettings_set('org.gnome.desktop.peripherals.mouse', 'speed', str(v))
        st.set_text(f'Pointer speed: {v}')
        GLib.timeout_add(2000, lambda: st.set_text('') or False)

    speed_scale.connect('value-changed', on_speed)
    c1.pack_start(row('Pointer Speed', 'Adjust mouse cursor speed', speed_scale), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)

    # Natural scrolling
    nat_sw = Gtk.Switch()
    cur_nat = 'true' in _shell("gsettings get org.gnome.desktop.peripherals.mouse natural-scroll 2>/dev/null").lower()
    nat_sw.set_active(cur_nat)

    def on_nat(sw, _):
        v = 'true' if sw.get_active() else 'false'
        _gsettings_set('org.gnome.desktop.peripherals.mouse', 'natural-scroll', v)
        st.set_text(f'Natural scrolling: {v}')
        GLib.timeout_add(2000, lambda: st.set_text('') or False)

    nat_sw.connect('notify::active', on_nat)
    c1.pack_start(row('Natural Scrolling', 'Reverse scroll direction (like a touchpad)', nat_sw), False, False, 0)
    c1.pack_start(hsep(), False, False, 0)

    # Cursor size
    cur_size = _gsettings_get('org.gnome.desktop.interface', 'cursor-size', '24')
    size_combo = themed_combo(['16', '24', '32', '48', '64'], cur_size,
        lambda v: (_gsettings_set('org.gnome.desktop.interface', 'cursor-size', v),
                   st.set_text(f'✓  Cursor size: {v}px (may need re-login)'),
                   GLib.timeout_add(2500, lambda: st.set_text('') or False)))
    c1.pack_start(row('Cursor Size', 'Size of the mouse pointer in pixels', size_combo), False, False, 0)

    b.pack_start(c1, False, False, 0)
    b.pack_start(st, False, False, 0)
    return s

def page_startup():
    s, b = page_box()
    b.pack_start(page_title('Startup Programs', 'Manage applications that run on login'), False, False, 0)
    st = status_label()

    autostart_path = os.path.expanduser('~/.config/labwc/autostart')
    user_autostart = os.path.expanduser('~/.config/blazzcore/autostart.d')
    os.makedirs(user_autostart, exist_ok=True)

    programs_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)

    def get_user_entries():
        entries = []
        for f in sorted(os.listdir(user_autostart)):
            if f.endswith('.sh'):
                path = os.path.join(user_autostart, f)
                try:
                    cmd = open(path).read().strip().split('\n')[-1]
                    enabled = os.access(path, os.X_OK)
                    entries.append({'file': f, 'path': path, 'cmd': cmd, 'enabled': enabled})
                except Exception:
                    pass
        return entries

    def refresh_list():
        for child in programs_box.get_children():
            programs_box.remove(child)
        entries = get_user_entries()
        if not entries:
            lbl = Gtk.Label(label='No custom startup programs. Click "Add" to create one.', xalign=0)
            lbl.get_style_context().add_class('dim')
            programs_box.pack_start(lbl, False, False, 0)
        for entry in entries:
            hb = Gtk.Box(spacing=8)
            hb.set_margin_top(2); hb.set_margin_bottom(2)
            sw = Gtk.Switch()
            sw.set_active(entry['enabled'])
            sw.connect('notify::active', lambda sw, _, p=entry['path']: (
                os.chmod(p, 0o755) if sw.get_active() else os.chmod(p, 0o644),
            ))
            lbl = Gtk.Label(label=entry['cmd'], xalign=0)
            lbl.set_ellipsize(3)
            rm_btn = btn('Remove', (lambda p=entry['path']: lambda: (
                os.remove(p), refresh_list(),
                st.set_text('Removed.'),
                GLib.timeout_add(2000, lambda: st.set_text('') or False)
            ))(), 'destructive')
            hb.pack_start(sw, False, False, 0)
            hb.pack_start(lbl, True, True, 0)
            hb.pack_end(rm_btn, False, False, 0)
            programs_box.pack_start(hb, False, False, 0)
        programs_box.show_all()

    def add_program():
        dialog = Gtk.Dialog(title='Add Startup Program', transient_for=s.get_toplevel(), flags=0)
        dialog.add_buttons('Add', Gtk.ResponseType.OK, 'Cancel', Gtk.ResponseType.CANCEL)
        area = dialog.get_content_area()
        area.set_margin_start(20); area.set_margin_end(20)
        area.set_margin_top(16); area.set_margin_bottom(8); area.set_spacing(10)
        area.pack_start(Gtk.Label(label='Command to run at login:', xalign=0), False, False, 0)
        entry = Gtk.Entry()
        entry.set_placeholder_text('e.g. /usr/bin/my-app --flag')
        area.pack_start(entry, False, False, 0)
        area.show_all()
        resp = dialog.run()
        cmd = entry.get_text().strip()
        dialog.destroy()
        if resp != Gtk.ResponseType.OK or not cmd:
            return
        name = re.sub(r'[^a-zA-Z0-9_-]', '_', cmd.split()[0].split('/')[-1])
        path = os.path.join(user_autostart, f'{name}.sh')
        with open(path, 'w') as f:
            f.write(f'#!/bin/bash\n{cmd} &\n')
        os.chmod(path, 0o755)
        refresh_list()
        st.set_text(f'✓  Added: {cmd}')
        GLib.timeout_add(2500, lambda: st.set_text('') or False)

    c1 = card()
    hdr = Gtk.Box(spacing=8)
    hdr.pack_start(Gtk.Label(label='Custom Startup Programs', xalign=0), True, True, 0)
    hdr.pack_end(btn('Add', add_program), False, False, 0)
    c1.pack_start(hdr, False, False, 0)
    c1.pack_start(programs_box, False, False, 0)
    b.pack_start(c1, False, False, 0)

    # Info card about autostart.d
    c2 = card()
    info = Gtk.Label(xalign=0)
    info.set_markup(
        '<small>Scripts are stored in <b>~/.config/blazzcore/autostart.d/</b>\n'
        'They are sourced by the session autostart on login.\n'
        'Toggle the switch to enable/disable without removing.</small>')
    info.get_style_context().add_class('dim')
    c2.pack_start(info, False, False, 0)
    b.pack_start(c2, False, False, 0)

    b.pack_start(st, False, False, 0)
    refresh_list()
    return s

def page_shortcuts():
    s, b = page_box()
    b.pack_start(page_title('Keyboard Shortcuts', 'Default keybindings reference'), False, False, 0)

    shortcuts = [
        ('General', [
            ('Super + Space', 'Open Start Menu'),
            ('Super + D', 'Open Start Menu (alt)'),
            ('Super + Return', 'Open Terminal'),
            ('Super + E', 'Open File Manager'),
            ('Super + L', 'Lock Screen'),
            ('Super + V', 'Clipboard History'),
            ('Alt + F4', 'Close Window'),
            ('Alt + F11', 'Toggle Fullscreen'),
        ]),
        ('Window Management', [
            ('Super + Left', 'Snap Window Left'),
            ('Super + Right', 'Snap Window Right'),
            ('Super + Up', 'Maximize Window'),
            ('Super + Down', 'Unmaximize / Restore'),
            ('Alt + Tab', 'Switch Windows'),
            ('Super + Tab', 'Switch Windows (alt)'),
        ]),
        ('Workspaces', [
            ('Super + 1–5', 'Switch to Workspace'),
            ('Super + Shift + 1–5', 'Move Window to Workspace'),
            ('Super + Scroll', 'Cycle Workspaces'),
        ]),
        ('Screenshots', [
            ('Print', 'Screenshot Full Screen'),
            ('Shift + Print', 'Screenshot Area'),
            ('Ctrl + Print', 'Screenshot to Clipboard'),
            ('Super + Shift + R', 'Screen Recording'),
        ]),
        ('Media', [
            ('Volume Up/Down', 'Adjust Volume'),
            ('Volume Mute', 'Toggle Mute'),
            ('Brightness Up/Down', 'Adjust Brightness'),
        ]),
    ]

    for section, binds in shortcuts:
        c = card()
        sec_lbl = Gtk.Label(label=section, xalign=0)
        sec_lbl.set_markup(f'<b>{section}</b>')
        c.pack_start(sec_lbl, False, False, 2)
        for i, (key, action) in enumerate(binds):
            hb = Gtk.Box(spacing=8)
            k = Gtk.Label(label=key, xalign=0)
            k.set_size_request(200, -1)
            k.set_markup(f'<b>{key}</b>')
            a = Gtk.Label(label=action, xalign=0)
            a.get_style_context().add_class('dim')
            hb.pack_start(k, False, False, 0)
            hb.pack_start(a, True, True, 0)
            c.pack_start(hb, False, False, 1)
            if i < len(binds) - 1:
                c.pack_start(hsep(), False, False, 0)
        b.pack_start(c, False, False, 0)

    return s

def page_about():
    s, b = page_box()
    b.pack_start(page_title('About BlazzCore', 'System information'), False, False, 0)
    st = status_label()
    c = card()
    c.pack_start(row('About This System', 'View detailed hardware and software info',
        btn('Open', lambda: run_bg('/usr/local/bin/blazzcore-about', st))), False, False, 0)
    b.pack_start(c, False, False, 0)

    # Quick info inline
    try:
        version = open('/etc/blazzcore-version').read().strip()
    except FileNotFoundError:
        version = 'BlazzCore'
    kernel  = _shell(['uname', '-r'])
    pkg_cnt = _shell('pacman -Q 2>/dev/null | wc -l') + ' packages'
    uptime  = _shell(['uptime', '-p'])

    c2 = card()
    for i, (k, v) in enumerate([
        ('Version',      version),
        ('Kernel',       kernel),
        ('Packages',     pkg_cnt),
        ('Uptime',       uptime),
    ]):
        hb = Gtk.Box(spacing=0)
        kl = Gtk.Label(label=k, xalign=0); kl.set_size_request(160, -1)
        kl.get_style_context().add_class('dim')
        vl = Gtk.Label(label=v, xalign=0)
        hb.pack_start(kl, False, False, 0)
        hb.pack_start(vl, True, True, 0)
        c2.pack_start(hb, False, False, 2)
        if i < 3:
            c2.pack_start(hsep(), False, False, 0)
    b.pack_start(c2, False, False, 0)
    b.pack_start(st, False, False, 0)
    return s

# ── Main window ───────────────────────────────────────────────────────────────
class SettingsApp(Gtk.Window):
    def __init__(self):
        super().__init__(title='BlazzCore Settings')
        self.set_default_size(900, 640)
        self.set_border_width(0)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.add(hbox)

        stack = Gtk.Stack()
        stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        stack.set_transition_duration(80)

        sidebar = Gtk.StackSidebar()
        sidebar.set_stack(stack)

        def _fix_single_click(widget, *_):
            if isinstance(widget, Gtk.ListBox):
                widget.set_activate_on_single_click(True)
                return
            if hasattr(widget, 'get_children'):
                for child in widget.get_children():
                    _fix_single_click(child)
        sidebar.connect("realize", _fix_single_click)

        pages = [
            ('display',    '  Display',      page_display),
            ('appearance', '  Appearance',   page_appearance),
            ('taskbar',    '  Taskbar',      page_taskbar),
            ('sound',      '  Sound',        page_sound),
            ('bluetooth',  '  Bluetooth',    page_bluetooth),
            ('network',    '  Network',      page_network),
            ('nightlight', '  Night Light',  page_nightlight),
            ('keyboard',   '  Keyboard',     page_keyboard),
            ('mouse',      '  Mouse',        page_mouse),
            ('shortcuts',  '  Shortcuts',    page_shortcuts),
            ('startup',    '  Startup Apps', page_startup),
            ('power',      '  Power',        page_power),
            ('datetime',   '  Date & Time',  page_datetime),
            ('updates',    '  Updates',      page_updates),
            ('drivers',    '  Drivers',      page_drivers),
            ('software',   '  Software',     page_software),
            ('about',      '  About',        page_about),
        ]

        self._built      = set()
        self._builders   = {}
        self._ph_to_name = {}
        for name, label, builder in pages:
            ph = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            stack.add_titled(ph, name, label)
            self._builders[name]     = (ph, builder)
            self._ph_to_name[id(ph)] = name

        stack.connect('notify::visible-child', self._on_page_change)
        self._build_page(pages[0][0])

        hbox.pack_start(sidebar, False, False, 0)
        hbox.pack_start(Gtk.Separator(orientation=Gtk.Orientation.VERTICAL), False, False, 0)
        hbox.pack_start(stack, True, True, 0)

    def _build_page(self, name):
        if name in self._built:
            return
        self._built.add(name)
        ph, builder = self._builders[name]
        widget = builder()
        widget.set_vexpand(True)
        ph.pack_start(widget, True, True, 0)
        ph.show_all()

    def _on_page_change(self, stack, _):
        child = stack.get_visible_child()
        if child is not None:
            name = self._ph_to_name.get(id(child))
            if name:
                self._build_page(name)


def main():
    win = SettingsApp()
    win.connect('destroy', Gtk.main_quit)
    win.show_all()
    Gtk.main()

if __name__ == '__main__':
    main()
