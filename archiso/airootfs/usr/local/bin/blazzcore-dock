#!/usr/bin/env bash
# BlazzCore dock position control

POSITION=$(zenity --list \
    --title="Dock Position" \
    --text="Choose where to show the dock:" \
    --column="Position" \
    "Bottom (default)" \
    "Left" \
    "Right" \
    "Top" \
    --width=300 --height=280 \
    --print-column=1 2>/dev/null)

[[ -z "$POSITION" ]] && exit 0

pkill nwg-dock 2>/dev/null

# Wait for old dock process to exit (up to 2 seconds)
for _ in {1..20}; do
    pgrep -x nwg-dock > /dev/null || break
    sleep 0.1
done

case "$POSITION" in
    "Bottom (default)") nwg-dock -p bottom -a center -i 38 -mb 0 -f & ;;
    "Left")             nwg-dock -p left   -a center -i 38 -ml 0 -f & ;;
    "Right")            nwg-dock -p right  -a center -i 38 -mr 0 -f & ;;
    "Top")              nwg-dock -p top    -a center -i 38 -mt 0 -f & ;;
esac
