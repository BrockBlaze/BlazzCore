#!/usr/bin/env bash
# BlazzCore dock position control

POSITION=$(zenity --list \
    --title="Dock Position" \
    --text="Choose where to show the dock:" \
    --column="Position" \
    "Bottom (default)" \
    "Left" \
    "Right" \
    "Top" \
    --width=300 --height=280 \
    --print-column=1 2>/dev/null)

[[ -z "$POSITION" ]] && exit 0

pkill nwg-dock 2>/dev/null

# Wait for old dock process to exit (up to 2 seconds)
for _ in {1..20}; do
    pgrep -x nwg-dock > /dev/null || break
    sleep 0.1
done

DOCK_CONF="$HOME/.config/blazzcore/dock.conf"
mkdir -p "$(dirname "$DOCK_CONF")"

case "$POSITION" in
    "Bottom (default)") nwg-dock -p bottom -a center -i 42 -mb 0 -f &; echo "DOCK_POSITION=bottom" > "$DOCK_CONF" ;;
    "Left")             nwg-dock -p left   -a center -i 42 -ml 0 -f &; echo "DOCK_POSITION=left"   > "$DOCK_CONF" ;;
    "Right")            nwg-dock -p right  -a center -i 42 -mr 0 -f &; echo "DOCK_POSITION=right"  > "$DOCK_CONF" ;;
    "Top")              nwg-dock -p top    -a center -i 42 -mt 0 -f &; echo "DOCK_POSITION=top"    > "$DOCK_CONF" ;;
esac
